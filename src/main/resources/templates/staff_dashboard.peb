<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Staff Dashboard</title>
  <link rel="stylesheet" href="/static/css/Staff_Dashboard.css">
</head>
<body>
<!-- SIDEBAR -->
<div class="app">
  <aside class="sidebar">
    <div class="brand">
      <div class="brand-badge">✈️</div>
      <div class="brand-title">SkyFlow Staff</div>
    </div>

    <!-- OPTIONS: SIDEBAR -->
    <div class="nav-title">MAIN MENU</div>
    <nav class="nav">
      <a class="active" href="/staff/dashboard" aria-current="page"><span class="ico">📊</span> Operations Control</a>
      <a href="/staff/flights"><span class="ico">✈️</span> Flight Scheduler</a>
      <a href="/staff/bookings"><span class="ico">📄</span> Bookings</a>
      <a href="/staff/inquiries"><span class="ico">💬</span> Customer Inquiries</a>
      <a href="/staff/notifications"><span class="ico">🔄</span> Change Requests</a>
      <a href="#" aria-disabled="true" tabindex="-1" onclick="return false;"><span class="ico">👤</span> Crew Assignments</a>
      <a href="#" aria-disabled="true" tabindex="-1" onclick="return false;"><span class="ico">📋</span> Compliance Reports</a>
    </nav>

    <div class="nav-title">SYSTEM</div>
    <nav class="nav">
      <a href="#" aria-disabled="true" tabindex="-1" onclick="return false;"><span class="ico">⚙️</span> Global Settings</a>
      <a href="#" aria-disabled="true" tabindex="-1" onclick="return false;"><span class="ico">⚠️</span> Alert Configuration</a>
    </nav>

    <div class="sidebar-footer">
      <a class="logout" href="/staff/logout"><span class="ico">↩️</span> Log Out</a>
    </div>
  </aside>

  <!-- OPTIONS: ACCOUNT -->
  <div class="main" role="main">
    <header class="topbar">
      <div class="right">
        <a class="top" href="#" data-large-font-toggle><span class="ico">🔤</span> Large Font</a>
        <div class="profile">
          <div class="avatar"></div>
          <div class="name">
            <b>{{ staffName }}</b>
            <span>{{ staffRole }}</span>
          </div>
        </div>
      </div>
    </header>
    
    <!-- INFORMATION SUMMARY -->
    <div class="content">
      <h1>Operational Overview</h1>

      <section class="cards">
        <div class="card">
          <div class="kpi">
            <span>Active Flights</span>
            <b>{{ activeFlights }}</b>
          </div>
        </div>

        <div class="card">
          <div class="kpi">
            <span>Departures Today</span>
            <b>{{ departuresToday }}</b>
          </div>
        </div>

        <div class="card">
          <div class="kpi">
            <span>Customer Inquiries</span>
            <b>{{ customerInquiries }}</b>
          </div>
        </div>
      </section>

      <section class="panel">
        <h2>Upcoming Outbound Flights</h2>

        <table>
          <thead>
            <tr>
              <th>Flight No.</th>
              <th>Destination</th>
              <th>Dep. Date</th>
              <th>Dep. Time</th>
              <th>Status</th>
              <th>Capacity</th>
            </tr>
          </thead>
          <tbody>
            {% if flights is not empty %}
              {% for f in flights %}
                <tr onclick="window.location.href='/staff/flights?q={{ f.no }}'" style="cursor:pointer;">
                  <td><b>{{ f.no }}</b></td>
                  <td>{{ f.dest }}</td>
                  <td>{{ f.depatureDate }}</td>
                  <td>{{ f.depatureTime }}</td>
                  <td>
                    <span class="status {{ f.status | lower }}">
                      <span class="s"></span>
                      {{ f.status }}
                    </span>
                  </td>
                  <td>{{ f.assignedSeats }}/{{ f.capacity }}</td>
                </tr>
              {% endfor %}
            {% else %}
              <tr>
                <td colspan="7" class="muted">No flights available.</td>
              </tr>
            {% endif %}
          </tbody>
        </table>

        <div class="bottom">
          <div>Signed in as <b>{{ staffEmail }}</b></div>
          <div class="links">
            <a href=" " aria-disabled="true" tabindex="-1" onclick="return false;">Operational Policy</a >
            <a href="#" aria-disabled="true" tabindex="-1" onclick="return false;">Help Desk</a >
          </div>
        </div>
      </section>

    </div>
  </div>
</div>

<!-- FOOTER -->
<footer>
  <span>© 2026 SkyFlow. All rights reserved</span>
  <div class="footer-links">
    <a href="/privacy">Privacy</a>
    <a href="/terms">Terms</a>
    <a href="/complaints">Help</a>
  </div>
</footer>
  <script src="/static/javascript/Large_Font.js"></script>
</body>
</html>
