<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>SkyFlow - Staff Login</title>
  <link rel="stylesheet" href="/static/css/Staff_Login.css">
</head>
<body>
  <div class="shell">
    <section class="hero">
      <div class="brand">
        <div class="brand-left">
          <div class="brand-badge">✈</div>
          <div>SkyFlow Staff</div>
        </div>
        <a class="toplink" href="#" data-large-font-toggle>Large Font</a >
      </div>

      <div class="pill">Staff Portal</div>

      <h1>Secure <span class="grad">Staff</span><br/>Access Panel.</h1>

      <p>
        Sign in with your staff credentials to manage flights, bookings, and support requests.
      </p >

      <div class="hero-cards">
        <div class="hcard">
          <div class="hcard-title"><span class="icon">🛡️</span> Role-based Access</div>
          <small>Staff accounts can be assigned roles for admin, support, and operations.</small>
        </div>
        <div class="hcard">
          <div class="hcard-title"><span class="icon">🧾</span> Manage Records</div>
          <small>View bookings, respond to complaints, and update flight status efficiently.</small>
        </div>
      </div>

      <div class="quote">“Fast and reliable admin tools.” — Ops Team</div>
    </section>

    <main class="panel">
      <div class="card">
        <a class="toplink" href="/login">Back To User Login</a >
        <h2>Staff Sign In</h2>
        <p class="sub">Enter your staff email and password to continue.</p >

        {% if error %}
          <div class="error">{{ error }}</div>
        {% endif %}

        <div class="row">
          <button class="btn" type="button" onclick="return false;" aria-label="Sign in with SSO">SSO</button>
          <button class="btn" type="button" onclick="return false;" aria-label="Sign in with security key">Security Key</button>
        </div>

        <div class="divider">OR CONTINUE WITH EMAIL</div>

        <form action="/staff/login" method="post">
          <label for="email">Staff Email</label>
          <div class="field">
            <input class="input" id="email" type="email" name="email" placeholder="staff@company.com" required />
          </div>

          <label for="password">Password</label>
          <div class="field">
            <input class="input" id="password" type="password" name="password" placeholder="••••••••" required />
          </div>

          <div class="meta">
            <label style="margin:0; display:flex; align-items:center; gap:8px; font-weight:600;">
              <input type="checkbox" onclick="return false;" />
              Remember me
            </label>
            <a href="#" onclick="return false;">Forgot password?</a >
          </div>

          <button class="primary" type="submit" aria-label="Sign in to staff portal">Sign In →</button>
        </form>

        <div class="cta">
          <span>Need a staff account?</span>
          <a href="/staff/register">Create Staff Account</a >
        </div>

        <div class="footer">
          <a href="#" onclick="return false;">Privacy Policy</a >
          <a href="#" onclick="return false;">Terms</a >
          <a href="#" onclick="return false;">Help</a >
        </div>
      </div>
    </main>
  </div>
  <script src="/static/javascript/Large_Font.js"></script>
</body>
</html>
