<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>My Bookings</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
  <link rel="stylesheet" href="/static/css/My_Bookings.css">
  <link rel="stylesheet" href="/static/css/Home.css">
</head>
<body>
  <!-- NAV -->
  <nav>
    <a href="/home" class="brand">
      <div class="brand-badge">✈️</div>
      <span class="brand-title">SkyFlow</span>
    </a >
    <div class="nav-right">
      <button type="button" class="btn-ghost" data-large-font-toggle>Large Font</button>
      <a href="/home" class="btn-ghost">Search</a >
      <a href="/profile" class="btn-primary">My Profile</a >
      <a href="/logout" class="btn-danger">Logout</a >
    </div>
  </nav>

  <!-- MAIN BOOKINGS -->
  <main class="wrap">
    <div class="page-top">
      <div>
        <h1>My Bookings</h1>
        <p class="sub">View your bookings, see full flight details, and manage cancellations.</p >
      </div>

      <form class="filters" action="/profile/bookings" method="get">
        <div>
          <label for="bookingStatusFilter">Filters</label>
          {% set s = statusFilter | default("") %}
          <select id="bookingStatusFilter" name="status">
            <option value="" {% if s == "" %}selected{% endif %}>All statuses</option>
            <option value="pending" {% if s == "pending" %}selected{% endif %}>pending</option>
            <option value="confirmed" {% if s == "confirmed" %}selected{% endif %}>confirmed</option>
            <option value="cancelled" {% if s == "cancelled" %}selected{% endif %}>cancelled</option>
          </select>
        </div>

        <div>
          <label for="bookingIdFilter">Airport</label>
          <input class="input" id="bookingIdFilter" name="q" value="{{ q | default('') }}" placeholder="e.g. Heathrow" />
        </div>

        <button class="btn" type="submit" aria-label="Apply booking filters">Apply</button>
        <a class="btn" href="/profile/bookings">Clear</a >
      </form>
    </div>

    <!-- BOOKINGS LIST -->
    {% if bookings is empty %}
      <div class="empty" role="status">No bookings found.</div>
    {% else %}
      <div class="list">
        {% for b in bookings %}
          {% set bs = (b.bookingStatus | default('')) | lower %}
          <div class="card">

            <div class="card-top">
              <div>
                <div class="btitle">
                  {% if b.segments is not empty %}
                    {{ b.segments[0].originName }} → {{ b.segments[0].destName }}
                  {% else %}
                    Booking #{{ b.bookingReference }}
                  {% endif %}
                </div>
                <div class="meta">
                  <div class="pill {{ bs }}">
                    <span class="dot"></span>
                    Status: {{ b.bookingStatus }}
                  </div>
                  <div class="created-at">Ref: {{ b.bookingReference }}</div>
                  <div class="created-at">{{ b.createdAt }}</div>
                </div>
              </div>

              {% if b.bookingStatus != "cancelled" %}
                <div class="actions">
                  <a class="btn" href="/profile/bookings/change?bookingId={{ b.bookingId }}">Change</a>
                  <form action="/profile/bookings/cancel" method="post" style="margin:0;">
                    <input type="hidden" name="bookingId" value="{{ b.bookingId }}" />
                    <button class="a red" type="button" onclick="openCancel({{ b.bookingId }})" aria-label="Cancel booking {{ b.bookingReference }}">Cancel</button>
                  </form>
                </div>
              {% else %}
                <form action="/profile/bookings/delete" method="post" style="margin:0;">
                  <input type="hidden" name="bookingId" value="{{ b.bookingId }}" />
                  <button class="a red" type="button" onclick="openDelete({{ b.bookingId }})" aria-label="Delete booking {{ b.bookingReference }}">Delete</button>
                </form>
              {% endif %}
            </div>

            <div class="segments">
              {% if b.segments is empty %}
                <div class="seg">
                  <div class="seg-left">
                    <div class="seg-main">No flight details available</div>
                    <div class="seg-sub">This booking has no segments linked to it.</div>
                  </div>
                </div>
              {% else %}
                {% if bs == "cancelled" %}
                  <div class="seg">
                    <div class="seg-left">
                      <div class="seg-main" style="color: rgba(239,68,68,.80);">Booking Cancelled</div>
                      <div class="seg-sub">All passengers on this booking have been removed.</div>
                    </div>
                  </div>
                {% else %}
                  {% for seg in b.segments %}
                    <div class="seg">
                      <div class="seg-left">
                        <div class="seg-main">
                          {% if seg.originIata %}{{ seg.originIata }}{% else %}—{% endif %}
                          {% if seg.originName %}<span style="color:rgba(255,255,255,.55);font-weight:800;"> ({{ seg.originName }})</span>{% endif %}
                          →
                          {% if seg.destIata %}{{ seg.destIata }}{% else %}—{% endif %}
                          {% if seg.destName %}<span style="color:rgba(255,255,255,.55);font-weight:800;"> ({{ seg.destName }})</span>{% endif %}
                        </div>
                      </div>

                      <!-- Used Claude AI to generate syntax for openSeatModal params, lines 138-150 -->
                      <div class="seg-right">
                        <button class="mini-pill" type="button"
                          onclick="openSeatModal(
                            '{% if seg.originName %}{{ seg.originName }}{% else %}{{ seg.originIata }}{% endif %}',
                            '{% if seg.destName %}{{ seg.destName }}{% else %}{{ seg.destIata }}{% endif %}',
                            '{% if seg.originCity %}{{ seg.originCity }}{% else %}{{ seg.originIata }}{% endif %}',
                            '{% if seg.destCity %}{{ seg.destCity }}{% else %}{{ seg.destIata }}{% endif %}',
                            '{{ seg.originIata| default('—') }}',
                            '{{ seg.destIata | default('—') }}',
                            '{{ seg.flightNumber | default('—') }}',
                            '{{ seg.dep | default('—') }}',
                            '{{ seg.arr | default('—') }}',
                            '{{ seg.flightStatus | default('—') }}',
                            '{{ seg.passengers }}'
                          )">
                          View Ticket
                        </button>
                      </div>
                    </div>
                  {% endfor %}
                {% endif %}
              {% endif %}
            </div>

          </div>
        {% endfor %}
      </div>
    {% endif %}

  </main>

  <!-- CANCEL CONFIRMATION POPUP -->
  <div class="modal-backdrop" id="cancelModal" role="dialog" aria-modal="true" aria-hidden="true" aria-labelledby="cancelModalTitle" aria-describedby="cancelModalDescription" tabindex="-1">
    <div class="modal">
      <div class="modal-title" id="cancelModalTitle">Cancel Booking?</div>
      <p class="modal-sub" id="cancelModalDescription">This action cannot be undone. Your booking will be permanently cancelled.</p>
      <div class="modal-actions">
        <button class="btn" type="button" onclick="closeCancel()" aria-label="Go back without cancelling booking">Go Back</button>
        <form id="cancelForm" action="/profile/bookings/cancel" method="post" style="margin:0;">
          <input type="hidden" name="bookingId" id="cancelBookingId" />
          <button class="a red" type="submit" aria-label="Confirm cancel booking">Yes, Cancel</button>
        </form>
      </div>
    </div>
  </div>

  <!-- DELETE CONFIRMATION POPUP -->
  <div class="modal-backdrop" id="deleteModal" role="dialog" aria-modal="true" aria-hidden="true" aria-labelledby="deleteModalTitle" aria-describedby="deleteModalDescription" tabindex="-1">
    <div class="modal">
      <div class="modal-title" id="deleteModalTitle">Delete Booking?</div>
      <p class="modal-sub" id="deleteModalDescription">This action cannot be undone. Your booking will be permanently deleted.</p>
      <div class="modal-actions">
        <button class="btn" type="button" onclick="closeDelete()" aria-label="Go back without deleting booking">Go Back</button>
        <form id="deleteForm" action="/profile/bookings/delete" method="post" style="margin:0;">
          <input type="hidden" name="bookingId" id="deleteBookingId" />
          <button class="a red" type="submit" aria-label="Confirm delete booking">Yes, delete</button>
        </form>
      </div>
    </div>
  </div>

  <!-- FLIGHTS DETAILS MODAL -->
  <div class="modal-backdrop" id="seatModal" role="dialog" aria-modal="true" aria-hidden="true" aria-labelledby="seatModalTitle" tabindex="-1">
    <div class="modal">
      <div class="flight-details-modal-header">
        <div class="modal-title" id="seatModalTitle">Flight Details</div>
        <button class="btn flight-details-modal-close" type="button" onclick="closeSeatModal()">✕</button>
      </div>

      <div id="seatModalBody" class="flight-details-modal-body">
        <div class="flight-details-modal-row">
          <span class="flight-details-modal-label">Route</span>
          <span id="seatModalRoute" class="flight-details-modal-value"></span>
        </div>
        <div class="flight-details-modal-row">
          <span class="flight-details-modal-label">Flight Number</span>
          <span id="seatModalFlight" class="flight-details-modal-value"></span>
        </div>
        <div class="flight-details-modal-row">
          <span class="flight-details-modal-label">Departure</span>
          <span id="seatModalDep" class="flight-details-modal-value"></span>
        </div>
        <div class="flight-details-modal-row">
          <span class="flight-details-modal-label">Arrival</span>
          <span id="seatModalArr" class="flight-details-modal-value"></span>
        </div>
        <div class="flight-details-modal-row">
          <span class="flight-details-modal-label">Status</span>
          <span id="seatModalStatus" class="flight-details-modal-value"></span>
        </div>
        <div class="flight-details-modal-row" style="margin-top:8px;">
          <span class="flight-details-modal-label">Passengers</span>
        </div>
        <div id="seatModalPassengers" class="flight-details-modal-body"></div>
      </div>
    </div>
  </div>

  <!-- FOOTER -->
  <footer>
    <span>© 2026 SkyFlow. All rights reserved</span>
    <div class="footer-links">
      <a href="/privacy">Privacy</a>
      <a href="/terms">Terms</a>
      <a href="/complaints">Help</a>
    </div>
  </footer>

  <script src="/static/javascript/My_Bookings.js"></script>
  
  <script src="/static/javascript/Large_Font.js"></script>
</body>
</html>
