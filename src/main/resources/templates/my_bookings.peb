<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>My Bookings</title>
  <link rel="stylesheet" href="/static/css/My_Bookings.css">
  <link rel="stylesheet" href="/static/css/Home.css">
</head>
<body>
  <!-- NAV -->
  <nav>
    <a href=" " class="brand">
      <div class="brand-badge">✈️</div>
      <span class="brand-title">SkyFlow</span>
    </a >
    <div class="nav-right">
      <a href="#" class="btn-ghost" data-large-font-toggle>Large Font</a>
      <a href="/home" class="btn-ghost">Search</a >
      <a href="/profile" class="btn-primary">My Profile</a >
      <a href="/logout" class="btn-danger">Logout</a >
    </div>
  </nav>

  <!-- MAIN BOOKINGS -->
  <div class="wrap">
    <div class="page-top">
      <div>
        <h1>My Bookings</h1>
        <p class="sub">View your bookings, see full flight details, and manage cancellations.</p >
      </div>

      <form class="filters" action="/profile/bookings" method="get">
        <div>
          <label>Filters</label>
          {% set s = statusFilter | default("") %}
          <select name="status">
            <option value="" {% if s == "" %}selected{% endif %}>All statuses</option>
            <option value="pending" {% if s == "pending" %}selected{% endif %}>pending</option>
            <option value="confirmed" {% if s == "confirmed" %}selected{% endif %}>confirmed</option>
            <option value="cancelled" {% if s == "cancelled" %}selected{% endif %}>cancelled</option>
          </select>
        </div>

        <div>
          <label>Booking ID</label>
          <input class="input" name="q" value="{{ q | default('') }}" placeholder="e.g. 4" />
        </div>

        <button class="btn" type="submit" aria-label="Apply booking filters">Apply</button>
        <a class="btn" href="/profile/bookings">Clear</a >
      </form>
    </div>

    <!-- BOOKINGS LIST -->
    {% if bookings is empty %}
      <div class="empty">No bookings found.</div>
    {% else %}
      <div class="list">
        {% for b in bookings %}
          {% set bs = (b.bookingStatus | default('')) | lower %}
          <div class="card">

            <div class="card-top">
              <div>
                <div class="btitle">Booking Ref: {{ b.bookingReference }}</div>
                <div class="meta">
                  <div class="pill {{ bs }}">
                    <span class="dot"></span>
                    Status: {{ b.bookingStatus }}
                  </div>
                  <div class="created-at">Created: {{ b.createdAt }}</div>
                </div>
              </div>

              {% if b.bookingStatus != "cancelled" %}
                <div class="actions">
                  <a class="btn" href="/profile/bookings/change?bookingId={{ b.bookingId }}">Change</a >
                  <form action="/profile/bookings/cancel" method="post" style="margin:0;">
                    <input type="hidden" name="bookingId" value="{{ b.bookingId }}" />
                    <button class="a red" type="button" onclick="openCancel({{ b.bookingId }})" aria-label="Cancel booking {{ b.bookingReference }}">Cancel</button>
                  </form>
                </div>
              {% else %}
                <form action="/profile/bookings/delete" method="post" style="margin:0;">
                  <input type="hidden" name="bookingId" value="{{ b.bookingId }}" />
                  <button class="a red" type="button" onclick="openDelete({{ b.bookingId }})" aria-label="Delete booking {{ b.bookingReference }}">Delete</button>
                </form>
              {% endif %}
            </div>

            <div class="segments">
              {% if b.segments is empty %}
                <div class="seg">
                  <div class="seg-left">
                    <div class="seg-main">No flight details available</div>
                    <div class="seg-sub">This booking has no segments linked to it.</div>
                  </div>
                </div>
              {% else %}
                {% for seg in b.segments %}
                  <div class="seg">
                    <div class="seg-left">
                      <div class="seg-main">
                        {% if seg.originIata %}{{ seg.originIata }}{% else %}—{% endif %}
                        {% if seg.originName %}<span style="color:rgba(255,255,255,.55);font-weight:800;"> ({{ seg.originName }})</span>{% endif %}
                        →
                        {% if seg.destIata %}{{ seg.destIata }}{% else %}—{% endif %}
                        {% if seg.destName %}<span style="color:rgba(255,255,255,.55);font-weight:800;"> ({{ seg.destName }})</span>{% endif %}
                      </div>

                      <div class="seg-sub">
                        Flight:
                        {% if seg.flightNumber and seg.flightNumber != "" %}{{ seg.flightNumber }}{% else %}—{% endif %}
                        • Dep: {% if seg.dep and seg.dep != "" %}{{ seg.dep }}{% else %}—{% endif %}
                        • Arr: {% if seg.arr and seg.arr != "" %}{{ seg.arr }}{% else %}—{% endif %}
                      </div>
                    </div>

                    <div class="seg-right">
                      {% if seg.flightStatus and seg.flightStatus != "" %}
                        <span class="mini-pill">{{ seg.flightStatus }}</span>
                      {% endif %}

                      <span class="mini-pill">
                        Seat:
                        {% if seg.seatCode %}{{ seg.seatCode }}{% else %}No seat{% endif %}
                      </span>
                    </div>
                  </div>
                {% endfor %}
              {% endif %}
            </div>

          </div>
        {% endfor %}
      </div>
    {% endif %}

  </div>

  <!-- CANCEL CONFIRMATION POPUP -->
  <div class="modal-backdrop" id="cancelModal">
    <div class="modal">
      <div class="modal-title">Cancel Booking?</div>
      <p class="modal-sub">This action cannot be undone. Your booking will be permanently cancelled.</p>
      <div class="modal-actions">
        <button class="btn" type="button" onclick="closeCancel()" aria-label="Go back without cancelling booking">Go Back</button>
        <form id="cancelForm" action="/profile/bookings/cancel" method="post" style="margin:0;">
          <input type="hidden" name="bookingId" id="cancelBookingId" />
          <button class="a red" type="submit" aria-label="Confirm cancel booking">Yes, Cancel</button>
        </form>
      </div>
    </div>
  </div>

  <!-- DELETE CONFIRMATION POPUP -->
  <div class="modal-backdrop" id="deleteModal">
    <div class="modal">
      <div class="modal-title">Delete Booking?</div>
      <p class="modal-sub">This action cannot be undone. Your booking will be permanently deleted.</p>
      <div class="modal-actions">
        <button class="btn" type="button" onclick="closeDelete()" aria-label="Go back without deleting booking">Go Back</button>
        <form id="cancelForm" action="/profile/bookings/delete" method="post" style="margin:0;">
          <input type="hidden" name="bookingId" id="deleteBookingId" />
          <button class="a red" type="submit" aria-label="Confirm delete booking">Yes, delete</button>
        </form>
      </div>
    </div>
  </div>

  <!-- FOOTER -->
  <footer>
    <span>© 2026 SkyBook. All rights reserved</span>
    <div class="footer-links">
      <a href="/privacy">Privacy</a>
      <a href="/terms">Terms</a>
      <a href="/help">Help</a>
      <a href="/complaints">Complaints</a>
    </div>
  </footer>

  <script src="/static/javascript/My_Bookings.js"></script>
  
  <script src="/static/javascript/Large_Font.js"></script>
</body>
</html>
