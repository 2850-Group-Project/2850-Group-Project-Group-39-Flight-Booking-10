<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Create Account - SkyFlow</title>
  <link rel="stylesheet" href="/static/css/Register.css">
</head>

<body>
  <header class="topbar">
    <div class="brand">
      <div class="brand-badge">✈</div>
      <div>SkyFlow</div>
    </div>
    <div class="top-actions">
      <span>Already have an account?</span>
      <a href="/login">Log In</a >
    </div>
  </header>

  <div class="shell">
    <section class="hero">
      <div class="tag">SKYFLOW LOYALTY</div>

      <h1>Your global adventure starts here.</h1>

      <p>
        Join millions of travelers exploring the world with curated flights, exclusive lounge access,
        and premium rewards.
      </p >

      <div class="feature-list">
        <div class="feature">
          <div class="ficon">⭐</div>
          <div>
            <b>Earn Miles Instantly</b>
            <small>Get bonus miles for signing up today. Redeem on any flight.</small>
          </div>
        </div>

        <div class="feature">
          <div class="ficon">⚡</div>
          <div>
            <b>Priority Booking</b>
            <small>Early access to seasonal sales and flash deals before everyone else.</small>
          </div>
        </div>

        <div class="feature">
          <div class="ficon">🎁</div>
          <div>
            <b>Exclusive Perks</b>
            <small>Member-only upgrades, extra baggage, and complimentary in-flight Wi-Fi.</small>
          </div>
        </div>
      </div>
    </section>

    <main class="panel">
      <div class="card">
        <h2>Create your SkyFlow account</h2>
        <p class="sub">Sign up to unlock exclusive flight deals and manage your trips effortlessly.</p >

        {% if error %}
          <div class="error">{{ error }}</div>
        {% endif %}

        <div class="row2">
          <button class="btn" type="button" onclick="return false;">Google</button>
          <button class="btn" type="button" onclick="return false;">Apple</button>
        </div>

        <div class="divider">OR CONTINUE WITH EMAIL</div>

        <form action="/register" method="post">
          <div class="grid">
            <div>
              <label for="firstName">First Name</label>
              <input class="input" id="firstName" name="firstName" type="text" placeholder="e.g., Jonathan" />
            </div>
            <div>
              <label for="lastName">Last Name</label>
              <input class="input" id="lastName" name="lastName" type="text" placeholder="e.g., Wick" />
            </div>
          </div>

          <label for="email">Email Address</label>
          <input class="input" id="email" type="email" name="email" placeholder="name@example.com" required />

          <label for="password">Create Password</label>
          <input class="input" id="password" type="password" name="password" placeholder="••••••••" required />

          <label for="confirmPassword">Confirm Password</label>
          <input class="input" id="confirmPassword" type="password" name="confirmPassword" placeholder="••••••••" required />

          <div class="strength">
            <span class="dot"></span>
            <span>STRONG PASSWORD</span>
          </div>

          <div class="checks">
            <label>
              <input type="checkbox" checked />
              <span>Join SkyFlow Loyalty Program<br/><span style="color:rgba(255,255,255,.55);font-weight:600;">Enroll for free to start earning miles on every flight and unlock exclusive lounge access.</span></span>
            </label>

            <label>
              <input type="checkbox" required />
              <span>I agree to the <a href="#" onclick="return false;">Terms of Service</a > and <a href="#" onclick="return false;">Privacy Policy</a >.</span>
            </label>
          </div>

          <button class="primary" type="submit">Create Account →</button>
        </form>

        <div class="secure">
          <div class="lock">🔒</div>
          <div>Secure 256-bit SSL Encrypted Connection</div>
        </div>
      </div>
    </main>
  </div>

  <footer class="bottombar">
    <div class="links">
      <a href="#" onclick="return false;">Privacy Policy</a >
      <a href="#" onclick="return false;">Terms of Service</a >
      <a href="#" onclick="return false;">Cookie Settings</a >
      <a href="#" onclick="return false;">Contact Support</a >
    </div>
    <div>© 2026 SkyBook. All rights reserved</div>
  </footer>
</body>
</html>