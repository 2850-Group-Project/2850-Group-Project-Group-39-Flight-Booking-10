<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/static/css/Home.css">
  <link rel="stylesheet" href="/static/css/Flight_Search.css">
  <title>Choose Your Flight</title>
</head>
<body>
  <!-- NAV -->
  {% include "nav.peb" %}

  <main>
    <h1 class="sr-only">Choose Your Flight</h1>
    <!-- ROW 1: SEARCH SUMMARY -->
    <section class="search-summary">
      <div class="summary-inner">
        <div class="summary-route">
          <span class="summary-airport">{{ search.origin }}</span>
          {% if search.tripType == "return" %}
            <span class="summary-arrow">⇄</span>
          {% else %}
            <span class="summary-arrow">→</span>
          {% endif %}
          <span class="summary-airport">{{ search.destination }}</span>
        </div>
        <div class="summary-divider"></div>
        <div class="summary-meta">
          <div class="summary-item">
            <span class="summary-label">Departure</span>
            <span class="summary-value">{{ search.departureDate }}</span>
          </div>
          {% if search.tripType == "return" %}
          <div class="summary-item">
            <span class="summary-label">Return</span>
            <span class="summary-value">{{ search.returnDate }}</span>
          </div>
          {% endif %}
          <div class="summary-item">
            <span class="summary-label">Passengers</span>
            <span class="summary-value">
              {{ search.adults }} adult{% if search.adults != "1" %}s{% endif %}
              {% if search.children != "0" %}, {{ search.children }} child{% if search.children != "1" %}ren{% endif %}{% endif %}
              {% if search.infants != "0" %}, {{ search.infants }} infant{% if search.infants != "1" %}s{% endif %}{% endif %}
            </span>
          </div>
          <div class="summary-item">
            <span class="summary-label">Trip type</span>
            <span class="summary-value summary-badge">
              {% if search.tripType == "return" %}⇄ Return{% else %}→ One way{% endif %}
            </span>
          </div>
        </div>
        <a href="/home" class="btn-ghost summary-edit">Edit search</a>
      </div>
    </section>

    <section class="flights-section-container">
      <!-- ROW 2: OUTBOUND FLIGHTS -->
      <section class="flights-section" aria-labelledby="outbound-flights-title">
        <div class="flights-header">
          <div>
            <h2 class="flights-title" id="outbound-flights-title">
              <span class="flights-leg-badge outbound">Outbound</span>
              {{ search.origin }} → {{ search.destination }}
            </h2>
            <p class="flights-subtitle">Flights around {{ search.departureDate }}</p>
          </div>
          <div class="carousel-controls">
            <button class="carousel-btn" onclick="scrollCarousel('outbound', -1)" aria-label="Show previous outbound flights">‹</button>
            <button class="carousel-btn" onclick="scrollCarousel('outbound', 1)" aria-label="Show next outbound flights">›</button>
          </div>
        </div>

        <div class="carousel-track-wrapper">
          <div class="carousel-track" id="outbound-track" role="list" aria-label="Outbound flight options">
            {% for flight in outboundFlights %}
            <div class="flight-card" role="listitem" aria-label="Outbound flight {{ flight.flightNumber }} from {{ flight.originCode }} to {{ flight.destinationCode }}, departing {{ flight.departureTime }}, from £{{ flight.cheapestFare.price }}">
              <div class="flight-card-top">
                <div class="flight-time-block">
                  <span class="flight-time">{{ flight.departureTime }}</span>
                  <span class="flight-airport">{{ flight.originCode }}</span>
                </div>
                <div class="flight-duration">
                  <span class="flight-duration-label-departure-day">{{ flight.departureDay }}</span>
                  <div class="flight-duration-line">
                    <span class="flight-duration-dot"></span>
                    <span class="flight-duration-bar"></span>
                    <span class="flight-duration-dot"></span>
                  </div>
                  <span class="flight-duration-label">{{ flight.duration }}</span>
                </div>
                <div class="flight-time-block flight-time-block--right">
                  <span class="flight-time">{{ flight.arrivalTime }}</span>
                  <span class="flight-airport">{{ flight.destinationCode }}</span>
                </div>
              </div>
              <div class="flight-card-divider"></div>
              <div class="flight-card-bottom">
                <div class="flight-card-meta">
                  <span class="flight-number">Flight #{{ flight.flightNumber }}</span>
                  <span class="flight-status flight-status--{{ flight.status }}">{{ flight.status }}</span>
                </div>
                <div class="flight-card-right">
                  <div class="flight-price">
                    <span class="flight-price-from">from</span>
                    <span class="flight-price-amount">£{{ flight.cheapestFare.price }}</span>
                  </div>
                  <form onsubmit="selectFlight(event, this)" method="POST">
                    <input type="hidden" name="flightId" value="{{ flight.flightId }}" />
                    <input type="hidden" name="fareId" value="{{ flight.cheapestFare.fareId }}" />
                    <input type="hidden" name="leg" value="outbound" />
                    <input type="hidden" name="origin" value="{{ search.origin }}" />
                    <input type="hidden" name="destination" value="{{ search.destination }}" />
                    <input type="hidden" name="departureDate" value="{{ search.departureDate }}" />
                    <input type="hidden" name="returnDate" value="{{ search.returnDate }}" />
                    <input type="hidden" name="tripType" value="{{ search.tripType }}" />
                    <input type="hidden" name="adults" value="{{ search.adults }}" />
                    <input type="hidden" name="children" value="{{ search.children }}" />
                    <input type="hidden" name="infants" value="{{ search.infants }}" />
                    <button type="submit" class="btn-select" aria-label="Select outbound flight {{ flight.flightNumber }}" aria-pressed="false">Select →</button>
                  </form>
                </div>
              </div>
            </div>
            {% else %}
            <div class="flights-empty" role="status">
              <span class="flights-empty-icon">✈️</span>
              <p>No flights found around this date.</p>
              <a href="/home" class="btn-ghost">Search again</a>
            </div>
            {% endfor %}
          </div>
        </div>
      </section>

      <!-- ROW 3: RETURN FLIGHTS ONLY SHOWN FOR RETURN TRIPS -->
      {% if search.tripType == "return" %}
      <section class="flights-section" aria-labelledby="return-flights-title">
        <div class="flights-header">
          <div>
            <h2 class="flights-title" id="return-flights-title">
              <span class="flights-leg-badge return">Return</span>
              {{ search.destination }} → {{ search.origin }}
            </h2>
            <p class="flights-subtitle">Flights around {{ search.returnDate }}</p>
          </div>
          <div class="carousel-controls">
            <button class="carousel-btn" onclick="scrollCarousel('return', -1)" aria-label="Show previous return flights">‹</button>
            <button class="carousel-btn" onclick="scrollCarousel('return', 1)" aria-label="Show next return flights">›</button>
          </div>
        </div>

        <div class="carousel-track-wrapper">
          <div class="carousel-track" id="return-track" role="list" aria-label="Return flight options">
            {% for flight in returnFlights %}
            <div class="flight-card" role="listitem" aria-label="Return flight {{ flight.flightNumber }} from {{ flight.originCode }} to {{ flight.destinationCode }}, departing {{ flight.departureTime }}, from £{{ flight.cheapestFare.price }}">
              <div class="flight-card-top">
                <div class="flight-time-block">
                  <span class="flight-time">{{ flight.departureTime }}</span>
                  <span class="flight-airport">{{ flight.originCode }}</span>
                </div>
                <div class="flight-duration">
                  <span class="flight-duration-label-departure-day">{{ flight.departureDay }}</span>
                  <div class="flight-duration-line">
                    <span class="flight-duration-dot"></span>
                    <span class="flight-duration-bar"></span>
                    <span class="flight-duration-dot"></span>
                  </div>
                  <span class="flight-duration-label">{{ flight.duration }}</span>
                </div>
                <div class="flight-time-block flight-time-block--right">
                  <span class="flight-time">{{ flight.arrivalTime }}</span>
                  <span class="flight-airport">{{ flight.destinationCode }}</span>
                </div>
              </div>
              <div class="flight-card-divider"></div>
              <div class="flight-card-bottom">
                <div class="flight-card-meta">
                  <span class="flight-number">Flight #{{ flight.flightNumber }}</span>
                  <span class="flight-status flight-status--{{ flight.status }}">{{ flight.status }}</span>
                </div>
                <div class="flight-card-right">
                  <div class="flight-price">
                    <span class="flight-price-from">from</span>
                    <span class="flight-price-amount">£{{ flight.cheapestFare.price }}</span>
                  </div>
                  <form onsubmit="selectFlight(event, this)" method="POST">
                    <input type="hidden" name="flightId" value="{{ flight.flightId }}" />
                    <input type="hidden" name="fareId" value="{{ flight.cheapestFare.fareId }}" />
                    <input type="hidden" name="leg" value="return" />
                    <input type="hidden" name="origin" value="{{ search.origin }}" />
                    <input type="hidden" name="destination" value="{{ search.destination }}" />
                    <input type="hidden" name="departureDate" value="{{ search.departureDate }}" />
                    <input type="hidden" name="returnDate" value="{{ search.returnDate }}" />
                    <input type="hidden" name="tripType" value="{{ search.tripType }}" />
                    <input type="hidden" name="adults" value="{{ search.adults }}" />
                    <input type="hidden" name="children" value="{{ search.children }}" />
                    <input type="hidden" name="infants" value="{{ search.infants }}" />
                    <button type="submit" class="btn-select" aria-label="Select return flight {{ flight.flightNumber }}" aria-pressed="false">Select →</button>
                  </form>
                </div>
              </div>
            </div>
            {% else %}
            <div class="flights-empty" role="status">
              <span class="flights-empty-icon">✈️</span>
              <p>No return flights found around this date.</p>
              <a href="/home" class="btn-ghost">Search again</a>
            </div>
            {% endfor %}
          </div>
        </div>
      </section>
      {% endif %}
    </section>
    
    <div id="confirm-btn" class="confirm-btn" aria-live="polite">
      <a href="/flights/passengers" class="btn-primary confirm-btn-inner">
          Continue to passenger information →
      </a>
    </div>

  </main>

  <!-- FOOTER -->
  {% include "footer.peb" %}

  <script src="/static/javascript/FlightSearch.js"></script>

  <script src="/static/javascript/Large_Font.js"></script>
</body>
</html>
