<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Change Request</title>
  <link rel="stylesheet" href="/static/css/Change_Request.css">
  <link rel="stylesheet" href="/static/css/Home.css">
</head>
<body>
  <!-- MAIN BODY -->
  <div class="wrap">
    <div class="topbar">
      <div class="brand">
        <div class="brand-badge">✈</div>
        <div>SkyFlow</div>
      </div>
      <div class="right">
        <a class="navbtn" href="#" data-large-font-toggle>Large Font</a >
        <span class="pill">{{ userSession.firstName }} • {{ userSession.userEmail }}</span>
        <a class="navbtn" href="/profile/bookings">← My Bookings</a >
        <a class="navbtn red" href="/logout">Logout</a >
      </div>
    </div>

    <div class="grid">
      <!-- LEFT: CURRENT BOOKING INFO -->
      <div class="card">
        <h1>Change Request</h1>
        <p class="sub">Submit a request to change your flight/seat. A staff member will review and update the request status.</p >

        {% if error and error != "" %}
          <div class="msg err" role="alert">{{ error }}</div>
        {% endif %}
        {% if ok and ok != "" %}
          <div class="msg" role="status">{{ ok }}</div>
        {% endif %}

        <div class="kv">
          <div class="muted">Booking</div>
          <div><b>#{{ bookingId }}</b></div>
        </div>
        <div class="kv">
          <div class="muted">Current Flight</div>
          <div>
            <span class="badge">No. {{ currentFlightNumber }}</span>
            <div class="muted" style="margin-top:6px;">
              {{ currentOrigin }} {{ currentOriginName }} → {{ currentDest }} {{ currentDestName }}
            </div>
            <div class="muted" style="margin-top:6px;">
              Dep: {{ currentDep }}<br/>
              Arr: {{ currentArr }}
            </div>
          </div>
        </div>
        <div class="kv">
          <div class="muted">Current Seat</div>
          <div><span class="badge">{{ currentSeatCode }}</span></div>
        </div>

        <hr style="border:none;border-top:1px solid rgba(255,255,255,.10);margin:16px 0;">

        <form action="/profile/bookings/change" method="post">
          <input type="hidden" name="bookingId" value="{{ bookingId }}"/>
          <input type="hidden" name="segmentId" value="{{ segmentId }}"/>

          <label for="requestedFlightId">Requested Flight</label>
          <select id="requestedFlightId" name="requestedFlightId" required>
            {% if selectedFlightId and selectedFlightId != 0 %}
              <option value="{{ selectedFlightId }}" selected>Selected Flight ID: {{ selectedFlightId }}</option>
            {% else %}
              <option value="">Select a flight</option>
            {% endif %}
          </select>

          <div class="sub" style="margin-top:8px;">
            Tip: use the Flight Search panel to find a flight, then select it (this page reloads seats for the chosen flight).
          </div>

          <label for="requestedSeatId">Requested Seat (optional)</label>
          <select id="requestedSeatId" name="requestedSeatId">
            <option value="">No seat preference</option>
            {% if availableSeats is not empty %}
              {% for s in availableSeats %}
                <option value="{{ s.id }}">{{ s.seatCode }}{% if s.cabinClass %} • {{ s.cabinClass }}{% endif %}</option>
              {% endfor %}
            {% endif %}
          </select>

          <label for="reason">Reason (optional)</label>
          <textarea id="reason" name="reason" placeholder="e.g. Need a later flight / prefer an aisle seat / travel plan changed..."></textarea>

          <button class="btn" type="submit" aria-label="Submit change request">Submit Change Request →</button>
        </form>
      </div>

      <!-- RIGHT: SEARCH FLIGHTS + SELECT -->
      <div class="card">
        <h1>Flight Search</h1>
        <p class="sub">Search by flight number and pick a new flight. Seats shown on the left update after selecting a flight.</p >

        <form action="/profile/bookings/change" method="get" class="row" style="margin-top:10px;">
          <input type="hidden" name="bookingId" value="{{ bookingId }}"/>
          <label class="sr-only" for="flightQ">Search flight number</label>
          <input class="input" id="flightQ" name="flightQ" value="{{ flightQ }}" placeholder="Search flight no. (e.g. 101)"/>
          <button class="btn2" type="submit" aria-label="Search flights for change request">Search</button>
        </form>

        {% if flightResults is empty %}
          <div class="msg" role="status" style="margin-top:12px;">No results yet. Enter a flight number and search.</div>
        {% else %}
          <table>
            <thead>
              <tr>
                <th>ID</th>
                <th>No.</th>
                <th>Departure</th>
                <th>Arrival</th>
                <th>Status</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              {% for f in flightResults %}
                <tr>
                  <td>{{ f.id }}</td>
                  <td><b>{{ f.flightNumber }}</b></td>
                  <td class="muted">{{ f.dep }}</td>
                  <td class="muted">{{ f.arr }}</td>
                  <td>{{ f.status }}</td>
                  <td style="text-align:right;">
                    <a class="btn2"
                       href="/profile/bookings/change?bookingId={{ bookingId }}&flightQ={{ flightQ }}&selectedFlightId={{ f.id }}"
                       aria-label="Select flight {{ f.flightNumber }} for change request"
                       style="text-decoration:none;display:inline-block;">
                      Select
                    </a >
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>

          <div class="sub" style="margin-top:10px;">
            After selecting, update the “Requested Flight” dropdown on the left (it will show the selected ID).
          </div>
        {% endif %}
      </div>
    </div>
  </div>

  <!-- FOOTER -->
  <footer>
    <span>© 2026 SkyBook. All rights reserved</span>
    <div class="footer-links">
      <a href="/privacy">Privacy</a>
      <a href="/terms">Terms</a>
      <a href="/help">Help</a>
      <a href="/complaints">Complaints</a>
    </div>
  </footer>
  
  <script src="/static/javascript/Large_Font.js"></script>
</body>
</html>
