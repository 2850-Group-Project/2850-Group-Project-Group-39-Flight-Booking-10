<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>SkyFlow - Staff Registration</title>
  <link rel="stylesheet" href="/static/css/Staff_Register.css">
</head>
<body>
  <div class="shell">
    <section class="hero">
      <div class="brand">
        <div class="brand-left">
          <div class="brand-badge">✈</div>
          <div>SkyFlow Staff</div>
        </div>
      </div>

      <div class="pill">Staff Onboarding</div>

      <h1>Create Your <span class="grad">Staff</span><br/>Account.</h1>

      <p>
        Register your staff profile to access internal tools and operational dashboards.
      </p >

      <div class="hero-cards">
        <div class="hcard">
          <div class="hcard-title"><span class="icon">👤</span> Profile</div>
          <small>Add basic identity details for staff authentication and audit logs.</small>
        </div>
        <div class="hcard">
          <div class="hcard-title"><span class="icon">🏷️</span> Role</div>
          <small>Assign role (e.g., admin / customer_service) for access control.</small>
        </div>
      </div>
    </section>

    <!-- REGISTRATION -->
    <main class="panel">
      <div class="card">
        <h2>Staff Registration</h2>
        <p class="sub">Fill in the required fields to create a staff account.</p >

        {% if error %}
          <div class="error">{{ error }}</div>
        {% endif %}

        <form action="/staff/register" method="post">
          <label for="firstName">First Name</label>
          <input class="input" id="firstName" name="firstName" type="text" placeholder="Jane" required />

          <label for="lastName">Last Name</label>
          <input class="input" id="lastName" name="lastName" type="text" placeholder="Doe" required />

          <label for="email">Staff Email</label>
          <input class="input" id="email" name="email" type="email" placeholder="jane.doe@company.com" required />

          <label for="password">Password</label>
          <input class="input" id="password" name="password" type="password" placeholder="••••••••" required />

          <label for="confirmPassword">Confirm Password</label>
          <input class="input" id="confirmPassword" type="password" name="confirmPassword" placeholder="••••••••" required />

          <label for="inviteCode">Invite Code</label> 
          <input class="input" id="inviteCode" name="inviteCode" type="password" placeholder="Staff invite code" required />

          <label for="role">Role</label>
          <input class="input" id="role" name="role" type="text" placeholder="customer_service" />

          <button class="primary" type="submit">Create Account →</button>
        </form>

        <div class="cta">
          <span>Already registered?</span>
          <a href="/staff/login">Back to Login</a >
        </div>
      </div>
    </main>
  </div>
</body>
</html>