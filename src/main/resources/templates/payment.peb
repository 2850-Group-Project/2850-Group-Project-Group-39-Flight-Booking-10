<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <link rel="stylesheet" href="/static/css/Home.css">
  <link rel="stylesheet" href="/static/css/Flight_Search.css">
  <link rel="stylesheet" href="/static/css/Flight_Passengers.css">
  <link rel="stylesheet" href="/static/css/Payment.css">

  <title>Payment</title>
</head>
<body>
  <!-- NAV -->
  {% include "nav.peb" %}

  <main>
    <!-- SEARCH SUMMARY -->
    <section class="search-summary">
      <div class="summary-inner">
        <div class="summary-route">
          <span class="summary-airport">{{ bookingSession.search.origin }}</span>
          {% if bookingSession.search.tripType == "return" %}
            <span class="summary-arrow">⇄</span>
          {% else %}
            <span class="summary-arrow">→</span>
          {% endif %}
          <span class="summary-airport">{{ bookingSession.search.destination }}</span>
        </div>

        <div class="summary-divider"></div>

        <div class="summary-meta">
          <div class="summary-item">
            <span class="summary-label">Departure</span>
            <span class="summary-value">{{ bookingSession.search.departureDate }}</span>
          </div>

          {% if bookingSession.search.tripType == "return" %}
          <div class="summary-item">
            <span class="summary-label">Return</span>
            <span class="summary-value">{{ bookingSession.search.returnDate }}</span>
          </div>
          {% endif %}

          <div class="summary-item">
            <span class="summary-label">Passengers</span>
            <span class="summary-value">
              {{ bookingSession.search.adults }} adult{% if bookingSession.search.adults != "1" %}s{% endif %}
              {% if bookingSession.search.children != "0" %}, {{ bookingSession.search.children }} child{% if bookingSession.search.children != "1" %}ren{% endif %}{% endif %}
              {% if bookingSession.search.infants != "0" %}, {{ bookingSession.search.infants }} infant{% if bookingSession.search.infants != "1" %}s{% endif %}{% endif %}
            </span>
          </div>
        </div>

        <a href="/flights/passengers" class="btn-ghost summary-edit">Back to passengers</a>
      </div>
    </section>

    <!-- PAYMENT -->
    <section class="passengers-section">
      <div class="passengers-header">
        <div>
          <h1 class="passengers-title">Payment Details</h1>
          <p class="passengers-subtitle">Enter your card details to complete your booking.</p>
        </div>
        <div style="text-align: right;">
          <span style="font-size: 13px; color: rgba(255,255,255,.55);">Total</span>
          <div id="totalDisplay" aria-live="polite" style="font-size: 28px; font-weight: 900; letter-spacing: 0;">£{{ bookingTotal }}</div>
          <div id="pointsMsg" role="status" aria-live="polite" style="display:none; margin-top: 6px;">
            <span style="font-size: 13px; color: var(--good);">-£{{ maxDiscount }} discount applied</span><br/>
            <span style="font-size: 12px; color: rgba(255,255,255,.45);">{{ pointsAvailable }} pts redeemed</span>
          </div>
        </div>
      </div>


      <form method="POST" action="/payment" class="payment-form">

        <div class="passenger-card">
          <div class="passenger-card-header">
            <span class="passenger-type-badge passenger-type-badge--adult">Payment</span>
            <span class="passenger-card-title">Card Information</span>
          </div>

          <div class="passenger-fields">

            <div class="field-group">
              <label for="cardNumber">Card Number</label>
              <input type="text" id="cardNumber" name="cardNumber" placeholder="1234 5678 9012 3456" autocomplete="cc-number" required />
            </div>

            <div class="field-group field-group--narrow">
              <label for="expiry">Expiry</label>
              <input type="text" id="expiry" name="expiry" placeholder="MM/YY" autocomplete="cc-exp" required />
            </div>

            <div class="field-group field-group--narrow">
              <label for="cvv">CVV</label>
              <input type="password" id="cvv" name="cvv" placeholder="123" autocomplete="cc-csc" required />
            </div>

          </div>
        </div>

        <!-- USE POINTS -->
        <div class="passenger-card">
          <div class="passenger-card-header">
            <span class="passenger-type-badge passenger-type-badge--adult">Points</span>
            <span class="passenger-card-title">Redeem Points</span>
          </div>

          <div class="passenger-fields">
            <div class="field-group">
              <div style="font-size: 13px; color: rgba(255,255,255,.70); text-transform: none; letter-spacing: 0;">
                You have <span style="color: white; font-weight: 700;">{{ pointsAvailable }} points</span> 
                worth up to <span style="color: var(--good); font-weight: 700;">£{{ maxDiscount }}</span>
              </div>
              <input type="hidden" name="pointsToRedeem" id="pointsToRedeem" value="0" />
              <button type="button" id="usePointsBtn" class="btn-primary" onclick="togglePoints()" aria-label="Use loyalty points for this payment" aria-pressed="false" style="margin-top: 10px; width: fit-content;">Use Points</button>
            </div>
          </div>
        </div>


        <div class="passengers-submit">
          <button type="submit" class="btn-primary passengers-submit-btn" aria-label="Pay and continue">
            Pay and continue →
          </button>
        </div>

      </form>
    </section>

  </main>

  <!-- FOOTER -->
  {% include "footer.peb" %}

  <script>
    let pointsActive = false;
    const total = {{ bookingTotal }};
    function togglePoints() {
      pointsActive = !pointsActive;
      document.getElementById('pointsToRedeem').value = pointsActive ? {{ pointsAvailable }} : 0;
      const pointsButton = document.getElementById('usePointsBtn');
      pointsButton.textContent = pointsActive ? '✓ Remove Points' : 'Use Points';
      pointsButton.setAttribute('aria-pressed', pointsActive ? 'true' : 'false');
      pointsButton.setAttribute('aria-label', pointsActive ? 'Remove loyalty points from this payment' : 'Use loyalty points for this payment');
      document.getElementById('pointsMsg').style.display = pointsActive ? 'block' : 'none';
      document.getElementById('totalDisplay').textContent = pointsActive
        ? '£' + (total - {{ maxDiscount }}).toFixed(2)
        : '£{{ bookingTotal }}';
    }
  </script>
  <script src="/static/javascript/Large_Font.js"></script>
</body>
</html>
