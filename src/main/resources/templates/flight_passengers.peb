<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/static/css/Home.css">
  <link rel="stylesheet" href="/static/css/Flight_Search.css">
  <link rel="stylesheet" href="/static/css/Flight_Passengers.css">
  <title>Passenger Details</title>
</head>
<body>
  <!-- NAV -->
  <nav>
    {% if isLoggedIn %}
      <a href="/home" class="brand">
    {% else %}
      <a href="/" class="brand">
    {% endif %}
      <div class="brand-badge">✈️</div>
      <span class="brand-title">SkyFlow</span>
    </a>
    <div class="nav-right">
      <button type="button" class="btn-ghost" data-large-font-toggle>Large Font</button>
      <a href="/profile/bookings" class="btn-ghost">My Bookings</a>
      <a href="/profile" class="btn-primary">My Account<span class="notif-dot {% if unreadCount > 0 %}unread{% endif %}"></a>
    </div>
  </nav>

  <main>
    <!-- SEARCH SUMMARY -->
    <section class="search-summary">
      <div class="summary-inner">
        <div class="summary-route">
          <span class="summary-airport">{{ search.origin }}</span>
          {% if search.tripType == "return" %}
            <span class="summary-arrow">⇄</span>
          {% else %}
            <span class="summary-arrow">→</span>
          {% endif %}
          <span class="summary-airport">{{ search.destination }}</span>
        </div>
        <div class="summary-divider"></div>
        <div class="summary-meta">
          <div class="summary-item">
            <span class="summary-label">Departure</span>
            <span class="summary-value">{{ search.departureDate }}</span>
          </div>
          {% if search.tripType == "return" %}
          <div class="summary-item">
            <span class="summary-label">Return</span>
            <span class="summary-value">{{ search.returnDate }}</span>
          </div>
          {% endif %}
          <div class="summary-item">
            <span class="summary-label">Passengers</span>
            <span class="summary-value">
              {{ search.adults }} adult{% if search.adults != "1" %}s{% endif %}
              {% if search.children != "0" %}, {{ search.children }} child{% if search.children != "1" %}ren{% endif %}{% endif %}
              {% if search.infants != "0" %}, {{ search.infants }} infant{% if search.infants != "1" %}s{% endif %}{% endif %}
            </span>
          </div>
        </div>
        <a href="/home" class="btn-ghost summary-edit">Back to flights</a>
      </div>
    </section>

    <section class="passengers-section">
      <div class="passengers-header">
        <h1 class="passengers-title">Passenger Details</h1>
        <p class="passengers-subtitle">Please enter details exactly as they appear on each passenger's travel document.</p>
      </div>

      <form method="POST" action="/flights/passengers/submit">

        <!-- ADULTS -->
        {% for p in adults %}
        <div class="passenger-card">
          <div class="passenger-card-header">
            <span class="passenger-type-badge passenger-type-badge--adult">Adult</span>
            <span class="passenger-card-title">Adult {{ p.label }}</span>
          </div>
          <div class="passenger-fields">
            <input type="hidden" name="passengers[{{ p.idx }}][type]" value="adult" />

            <div class="field-group field-group--narrow">
              <span class="field-label">Title</span>
              <select name="passengers[{{ p.idx }}][title]" aria-label="Adult {{ p.label }} title" required>
                <option value="">—</option>
                <option value="Mr">Mr</option>
                <option value="Mrs">Mrs</option>
                <option value="Ms">Ms</option>
                <option value="Dr">Dr</option>
              </select>
            </div>

            <div class="field-group">
              <span class="field-label">First name</span>
              <input type="text" name="passengers[{{ p.idx }}][firstName]" aria-label="Adult {{ p.label }} first name" placeholder="As on passport" required />
            </div>

            <div class="field-group">
              <span class="field-label">Last name</span>
              <input type="text" name="passengers[{{ p.idx }}][lastName]" aria-label="Adult {{ p.label }} last name" placeholder="As on passport" required />
            </div>

            <div class="field-group">
              <span class="field-label">Date of birth</span>
              <input type="date" name="passengers[{{ p.idx }}][dateOfBirth]" aria-label="Adult {{ p.label }} date of birth" required />
            </div>

            <div class="field-group field-group--narrow">
              <span class="field-label">Gender</span>
              <select name="passengers[{{ p.idx }}][gender]" aria-label="Adult {{ p.label }} gender" required>
                <option value="">—</option>
                <option value="male">Male</option>
                <option value="female">Female</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div class="field-group">
              <span class="field-label">Email</span>
              <input type="email" name="passengers[{{ p.idx }}][email]" aria-label="Adult {{ p.label }} email" placeholder="For booking confirmation" />
            </div>

            <div class="field-group field-group--narrow">
              <span class="field-label">Nationality</span>
              <input type="text" name="passengers[{{ p.idx }}][nationality]" aria-label="Adult {{ p.label }} nationality" placeholder="e.g. GB" maxlength="2" />
            </div>

            <div class="passenger-card-divider"></div>
            <p class="passenger-section-label">Travel Document</p>

            <div class="field-group field-group--narrow">
              <span class="field-label">Document type</span>
              <select name="passengers[{{ p.idx }}][documentType]" aria-label="Adult {{ p.label }} document type">
                <option value="passport">Passport</option>
                <option value="id_card">ID Card</option>
              </select>
            </div>

            <div class="field-group">
              <span class="field-label">Document number</span>
              <input type="text" name="passengers[{{ p.idx }}][documentNumber]" aria-label="Adult {{ p.label }} document number" placeholder="e.g. 123456789" />
            </div>

            <div class="field-group field-group--narrow">
              <span class="field-label">Issuing country</span>
              <input type="text" name="passengers[{{ p.idx }}][documentCountry]" aria-label="Adult {{ p.label }} issuing country" placeholder="e.g. GB" maxlength="2" />
            </div>

            <div class="field-group">
              <span class="field-label">Expiry date</span>
              <input type="date" name="passengers[{{ p.idx }}][documentExpiry]" aria-label="Adult {{ p.label }} document expiry date" />
            </div>
          </div>
        </div>
        {% endfor %}

        <!-- CHILDREN -->
        {% for p in children %}
        <div class="passenger-card">
          <div class="passenger-card-header">
            <span class="passenger-type-badge passenger-type-badge--child">Child</span>
            <span class="passenger-card-title">Child {{ p.label }}</span>
          </div>
          <div class="passenger-fields">
            <input type="hidden" name="passengers[{{ p.idx }}][type]" value="child" />

            <div class="field-group field-group--narrow">
              <span class="field-label">Title</span>
              <select name="passengers[{{ p.idx }}][title]" aria-label="Child {{ p.label }} title">
                <option value="Master">Master</option>
                <option value="Miss">Miss</option>
              </select>
            </div>

            <div class="field-group">
              <span class="field-label">First name</span>
              <input type="text" name="passengers[{{ p.idx }}][firstName]" aria-label="Child {{ p.label }} first name" placeholder="As on passport" required />
            </div>

            <div class="field-group">
              <span class="field-label">Last name</span>
              <input type="text" name="passengers[{{ p.idx }}][lastName]" aria-label="Child {{ p.label }} last name" placeholder="As on passport" required />
            </div>

            <div class="field-group">
              <span class="field-label">Date of birth</span>
              <input type="date" name="passengers[{{ p.idx }}][dateOfBirth]" aria-label="Child {{ p.label }} date of birth" required />
            </div>

            <div class="field-group field-group--narrow">
              <span class="field-label">Gender</span>
              <select name="passengers[{{ p.idx }}][gender]" aria-label="Child {{ p.label }} gender">
                <option value="">—</option>
                <option value="male">Male</option>
                <option value="female">Female</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div class="field-group field-group--narrow">
              <span class="field-label">Nationality</span>
              <input type="text" name="passengers[{{ p.idx }}][nationality]" aria-label="Child {{ p.label }} nationality" placeholder="e.g. GB" maxlength="2" />
            </div>

            <div class="passenger-card-divider"></div>
            <p class="passenger-section-label">Travel Document</p>

            <div class="field-group field-group--narrow">
              <span class="field-label">Document type</span>
              <select name="passengers[{{ p.idx }}][documentType]" aria-label="Child {{ p.label }} document type">
                <option value="passport">Passport</option>
                <option value="id_card">ID Card</option>
              </select>
            </div>

            <div class="field-group">
              <span class="field-label">Document number</span>
              <input type="text" name="passengers[{{ p.idx }}][documentNumber]" aria-label="Child {{ p.label }} document number" />
            </div>

            <div class="field-group field-group--narrow">
              <span class="field-label">Issuing country</span>
              <input type="text" name="passengers[{{ p.idx }}][documentCountry]" aria-label="Child {{ p.label }} issuing country" placeholder="e.g. GB" maxlength="2" />
            </div>

            <div class="field-group">
              <span class="field-label">Expiry date</span>
              <input type="date" name="passengers[{{ p.idx }}][documentExpiry]" aria-label="Child {{ p.label }} document expiry date" />
            </div>
          </div>
        </div>
        {% endfor %}

        <!-- INFANTS -->
        {% for p in infants %}
        <div class="passenger-card">
          <div class="passenger-card-header">
            <span class="passenger-type-badge passenger-type-badge--infant">Infant</span>
            <span class="passenger-card-title">Infant {{ p.label }}</span>
          </div>
          <div class="passenger-fields">
            <input type="hidden" name="passengers[{{ p.idx }}][type]" value="infant" />

            <div class="field-group">
              <span class="field-label">First name</span>
              <input type="text" name="passengers[{{ p.idx }}][firstName]" aria-label="Infant {{ p.label }} first name" placeholder="As on passport" required />
            </div>

            <div class="field-group">
              <span class="field-label">Last name</span>
              <input type="text" name="passengers[{{ p.idx }}][lastName]" aria-label="Infant {{ p.label }} last name" placeholder="As on passport" required />
            </div>

            <div class="field-group">
              <span class="field-label">Date of birth</span>
              <input type="date" name="passengers[{{ p.idx }}][dateOfBirth]" aria-label="Infant {{ p.label }} date of birth" required />
            </div>

            <div class="field-group field-group--narrow">
              <span class="field-label">Nationality</span>
              <input type="text" name="passengers[{{ p.idx }}][nationality]" aria-label="Infant {{ p.label }} nationality" placeholder="e.g. GB" maxlength="2" />
            </div>

            <div class="passenger-card-divider"></div>
            <p class="passenger-section-label">Travel Document</p>

            <div class="field-group">
              <span class="field-label">Passport number</span>
              <input type="text" name="passengers[{{ p.idx }}][documentNumber]" aria-label="Infant {{ p.label }} passport number" />
            </div>

            <div class="field-group field-group--narrow">
              <span class="field-label">Issuing country</span>
              <input type="text" name="passengers[{{ p.idx }}][documentCountry]" aria-label="Infant {{ p.label }} issuing country" placeholder="e.g. GB" maxlength="2" />
            </div>

            <div class="field-group">
              <span class="field-label">Expiry date</span>
              <input type="date" name="passengers[{{ p.idx }}][documentExpiry]" aria-label="Infant {{ p.label }} document expiry date" />
            </div>
          </div>
        </div>
        {% endfor %}

        <div class="passengers-submit">
          <button type="submit" class="btn-primary passengers-submit-btn" aria-label="Continue to seat selection">
            Continue to seat selection →
          </button>
        </div>

      </form>
    </section>
  </main>

  <!-- FOOTER -->
  {% include "footer.peb" %}

  <script src="/static/javascript/Large_Font.js"></script>
</body>
</html>
