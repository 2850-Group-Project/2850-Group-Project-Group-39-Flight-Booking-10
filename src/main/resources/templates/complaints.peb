<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Submit a Complaint</title>
    <link rel="stylesheet" href="/static/css/Complaints.css">
    <link rel="stylesheet" href="/static/css/Home.css">
</head>
<body>
<nav>
    <a href="/" class="brand">
        <div class="brand-badge">✈️</div>
        <span class="brand-title">SkyFlow</span>
    </a>

    <div class="nav-right">
        <a href="/profile/bookings" class="btn-ghost">My Bookings</a>
        <a href="/profile" class="btn-primary">My Account</a>
    </div>
</nav>

<main>
  <div class="card">

    <div class="card-header">
      <p class="eyebrow">Support</p>
      <h1>Submit a <span>Complaint</span></h1>
      <p>Describe your issue and our team will follow up as soon as possible.</p>
    </div>

    <div class="divider"></div>

    {% if flash is defined %}
      <div class="flash {{ flash.type }}">
        {% if flash.type == "success" %}✓{% else %}✕{% endif %}
        {{ flash.message }}
      </div>
    {% endif %}

    <form action="/complaints/submit" method="POST">

      {# <input type="hidden" name="_csrf" value="{{ csrf }}"> #}
      <input type="hidden" name="userId" value="{{ userId }}">

      <div class="field">
        <label for="type">Complaint type</label>
        <div class="field-inner">
          <span class="field-icon">🏷</span>
          <select id="type" name="type" required>
            <option value="" disabled selected>Select a category</option>
            <option value="billing">Billing</option>
            <option value="service">Service</option>
            <option value="staff">Staff</option>
            <option value="technical">Technical</option>
            <option value="other">Other</option>
          </select>
        </div>
      </div>

      <div class="field">
        <label for="message">Your message</label>
        <div class="field-inner textarea-wrap">
          <textarea
            id="message"
            name="message"
            maxlength="1000"
            placeholder="Tell us what happened..."
            required
          ></textarea>
        </div>
        <div class="char-row">
          <span class="char-count" id="charCount">0 / 1000</span>
        </div>
      </div>

      <button type="submit" class="btn-submit">
        Submit complaint →
      </button>

    </form>
  </div>
</main>

<footer>
  <span>© 2025 SkyFlow</span>
  <div class="footer-links">
    <a href="/privacy">Privacy</a>
    <a href="/terms">Terms</a>
    <a href="/help">Help</a>
  </div>
</footer>

<script>
  const ta      = document.getElementById('message');
  const counter = document.getElementById('charCount');

  ta.addEventListener('input', () => {
    const len = ta.value.length;
    counter.textContent = `${len} / 1000`;
    counter.classList.toggle('warn', len > 800 && len <= 1000);
    counter.classList.toggle('over', len > 1000);
  });
</script>

</body>
</html>