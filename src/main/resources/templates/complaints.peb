<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Submit a Request</title>
    <link rel="stylesheet" href="/static/css/Complaints.css">
    <link rel="stylesheet" href="/static/css/Home.css">
</head>
<body>
  <!-- NAV -->
  <nav>
      <a href="/home" class="brand">
        <div class="brand-badge">✈️</div>
        <span class="brand-title">SkyFlow</span>
      </a>
      <div class="nav-right">
      <a href="#" class="btn-ghost" data-large-font-toggle>Large Font</a>
        <a href="/profile/bookings" class="btn-ghost">My Bookings</a>
        <a href="/profile" class="btn-primary">My Account</a>
      </div>
  </nav>

  <!-- MAIN BODY -->
  <main>
    <div class="card">

      <div class="card-header">
        <p class="eyebrow">Support</p>
        <h1>Submit a <span>Request</span></h1>
        <p>Describe your issue and our team will follow up as soon as possible.</p>
      </div>

      <div class="divider"></div>

      {% if success == "true" %}
        <div class="flash success">✓ Your request has been submitted! We'll be in touch soon.</div>
      {% endif %}

      {% if error == "missing_fields" %}
        <div class="flash error">✕ Please provide a full message.</div>
      {% endif %}

      {% if error == "server_error" %}
        <div class="flash error">✕ Sorry, something went wrong.</div>
      {% endif %}

      <form action="/complaints/submit" method="POST">

        {# <input type="hidden" name="_csrf" value="{{ csrf }}"> #}
        <input type="hidden" name="userId" value="{{ userId }}">

        <!-- REQUEST TYPE -->
        <div class="field">
          <label for="type">Request type</label>
          <div class="field-inner">
            <span class="field-icon">🏷</span>
            <select id="type" name="type" required>
              <option value="" disabled selected>Select a category</option>
              <option value="billing">Billing</option>
              <option value="service">Service</option>
              <option value="staff">Staff</option>
              <option value="technical">Technical</option>
              <option value="other">Other</option>
            </select>
          </div>
        </div>

        <!-- REQUEST FIELD -->
        <div class="field">
          <label for="message">Your message</label>
          <div class="field-inner textarea-wrap">
            <textarea
              id="message"
              name="message"
              maxlength="1000"
              placeholder="Tell us what happened..."
              required
            ></textarea>
          </div>
          <div class="char-row">
            <span class="char-count" id="charCount">0 / 1000</span>
          </div>
        </div>

        <button type="submit" class="btn-submit" aria-label="Submit complaint">
          Submit request →
        </button>

      </form>
    </div>
  </main>

  <!-- FOOTER -->
  <footer>
    <span>© 2026 SkyBook. All rights reserved</span>
    <div class="footer-links">
      <a href="/privacy">Privacy</a>
      <a href="/terms">Terms</a>
      <a href="/help">Help</a>
    </div>
  </footer>

  <script>
    const ta      = document.getElementById('message');
    const counter = document.getElementById('charCount');

    ta.addEventListener('input', () => {
      const len = ta.value.length;
      counter.textContent = `${len} / 1000`;
      counter.classList.toggle('warn', len > 800 && len <= 1000);
      counter.classList.toggle('over', len > 1000);
    });
  </script>

  <script src="/static/javascript/Large_Font.js"></script>
</body>
</html>
