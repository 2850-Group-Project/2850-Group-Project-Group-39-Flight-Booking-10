<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/static/css/Home.css">
  <link rel="stylesheet" href="/static/css/Seat_Selection.css">
  <title>SkyFlow - Seat Selection</title>
</head>

<body>

  <!-- NAV -->
  <nav>
    {% if isLoggedIn %}
      <a href="/home" class="brand">
    {% else %}
      <a href="/" class="brand">
    {% endif %}
      <div class="brand-badge">✈️</div>
      <span class="brand-title">SkyFlow</span>
    </a>
    <div class="nav-right">
      <a href="/profile/bookings" class="btn-ghost">My Bookings</a>
      <a href="/profile" class="btn-primary">My Account</a>
    </div>
  </nav>

  <main>
    <!-- FLIGHT SUMMARY -->
    <section class="flight-summary">
      <div class="summary-inner">
        <div class="summary-flight">
          <div class="summary-route">
            <span class="summary-airport">{{ originIata }}</span>
            <span class="summary-arrow">→</span>
            <span class="summary-airport">{{ destIata }}</span>
          </div>
          <span class="summary-flight-number">Flight #{{ flightNumber }}</span>
        </div>
        <div class="summary-divider"></div>
        <div class="summary-meta">
          <div class="summary-item">
            <span class="summary-label">Aircraft</span>
            <span class="summary-value">{{ aircraftType }}</span>
          </div>
          <div class="summary-item">
            <span class="summary-label">Selected Seat</span>
            <span class="summary-value">
              {% if currentSeatCode %}
                <span class="seat-badge">{{ currentSeatCode }}</span>
              {% else %}
                <span class="seat-badge-empty">—</span>
              {% endif %}
            </span>
          </div>
        </div>
        <a href="/flights/passengers" class="btn-ghost summary-edit">← Back</a>
      </div>
    </section>

    <!-- SEAT SELECTION SECTION -->
    <section class="seat-section-container">
      <div class="seat-card">
        <div class="seat-header">
          <div>
            <h1 class="seat-title">Seat Selection</h1>
            <p class="seat-subtitle">Choose a comfortable seat for your flight</p>
          </div>
        </div>

        <!-- MESSAGES -->
        {% if error %}
          <div class="msg msg-error">{{ error }}</div>
        {% endif %}
        {% if ok %}
          <div class="msg msg-success">{{ ok }}</div>
        {% endif %}

        <!-- PASSENGERS INFO -->
        <div class="seat-passengers">
          <h3 class="seat-passengers-title">Passengers on this flight</h3>
          <div class="passengers-list">
            {% for passenger in passengers %}
            <div class="passenger-item">
              <span class="passenger-icon">👤</span>
              <span class="passenger-name">{{ passenger.firstName }} {{ passenger.lastName }}</span>
            </div>
            {% endfor %}
          </div>
        </div>

        <!-- LEGEND -->
        <div class="seat-legend">
          <span class="legend-item">
            <span class="legend-square available"></span>
            <span>Available</span>
          </span>
          <span class="legend-item">
            <span class="legend-square occupied"></span>
            <span>Occupied</span>
          </span>
          <span class="legend-item">
            <span class="legend-square selected"></span>
            <span>Selected</span>
          </span>
        </div>

        <!-- CURRENT PASSENGER -->
        <div class="current-passenger-info">
          <span class="passenger-icon-large">👤</span>
          <div class="current-passenger-text">
            <span class="current-passenger-label">Assigning seat for</span>
            <span class="current-passenger-name">{{ currentPassenger }}</span>
          </div>
        </div>

        <!-- SEAT MAP -->
        <form action="/flights/seats" method="post" class="seat-form">
          <div class="seatmap-wrapper">
            <div class="seatmap">
              <div class="seatmap-header">Front of Aircraft</div>
              
              {% for row in seatRows %}
                <div class="seat-row">
                  <div class="row-num">{{ row.rowNumber }}</div>

                  <div class="row-seats">
                    {% for s in row.seats %}
                      {% if s.isAisleGap %}
                        <div class="aisle-gap"></div>
                      {% else %}
                        {% set cls = "seat" %}
                        {% if s.status == "occupied" %}
                          {% set cls = cls ~ " occupied" %}
                        {% else %}
                          {% set cls = cls ~ " available" %}
                        {% endif %}
                        {% if currentSeatCode and s.code == currentSeatCode %}
                          {% set cls = cls ~ " selected" %}
                        {% endif %}

                        <button
                          class="{{ cls }}"
                          type="submit"
                          name="seatCode"
                          value="{{ s.code }}"
                          {% if s.status == "occupied" %}disabled{% endif %}
                          title="{{ s.code }} ({{ s.position }})"
                        >
                          {{ s.letter }}
                        </button>
                      {% endif %}
                    {% endfor %}
                  </div>
                </div>
              {% endfor %}
            </div>
          </div>
        </form>
      </div>
    </section>

  </main>

  <!-- FOOTER -->
  <footer>
    <span>© 2026 SkyFlow. All rights reserved.</span>
    <div class="footer-links">
      <a href="/privacy">Privacy</a>
      <a href="/terms">Terms</a>
      <a href="/help">Help</a>
      <a href="/complaints">Complaints</a>
    </div>
  </footer>

</body>
</html>