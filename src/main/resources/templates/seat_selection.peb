<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/static/css/Home.css">
  <link rel="stylesheet" href="/static/css/Seat_Selection.css">
  <title>Seat Selection</title>
</head>
<body>
<!-- NAV -->
{% include "nav.peb" %}


<main>
  <!-- FLIGHT SUMMARY -->
  <section class="flight-summary">
    <div class="summary-inner">
      <div class="summary-flight">
        <div class="summary-route">
          <span class="summary-airport">{{ originIata }}</span>
          <span class="summary-arrow">→</span>
          <span class="summary-airport">{{ destIata }}</span>
        </div>
        <span class="summary-flight-number">Flight #{{ flightNumber }}</span>
      </div>
      <div class="summary-divider"></div>
      <div class="summary-meta">
        <div class="summary-item">
          <span class="summary-label">Aircraft</span>
          <span class="summary-value">{{ aircraftType }}</span>
        </div>
      </div>
      <a href="/flights/passengers" class="btn-ghost summary-edit">← Back</a>
    </div>
  </section>

  <!-- SEAT SELECTION -->
  <section class="seat-section-container">
    <div class="seat-card">
      <div class="seat-header">
        <div class="seat-header-left">
          <h1 class="seat-title">Seat Selection</h1>
          <p class="seat-subtitle">Choose a comfortable seat for your flight</p>
        </div>
      </div>

      <!-- MESSAGES -->
      {% if error %}
        <div class="msg msg-error" role="alert">{{ error }}</div>
      {% endif %}
      {% if ok %}
        <div class="msg msg-success" role="status">{{ ok }}</div>
      {% endif %}

      <!-- PASSENGERS INFO -->
      <h3 class="seat-passengers-title">Passengers on this flight</h3>
      <div class="passengers-list">
        {% for passenger in passengers %}
        <div class="passenger-item">
          <span class="passenger-icon">👤</span>
          <span class="passenger-name">{{ passenger.firstName }} {{ passenger.lastName }}</span>
        </div>
        {% endfor %}
      </div>

      <!-- SEAT AVAILABILITY KEY -->
      <div class="seat-legend">
        <span class="legend-item">
          <span class="legend-square available"></span>
          <span>Available</span>
        </span>
        <span class="legend-item">
          <span class="legend-square occupied"></span>
          <span>Occupied</span>
        </span>
        <span class="legend-item">
          <span class="legend-square selected"></span>
          <span>Selected</span>
        </span>
      </div>

      <!-- CURRENT PASSENGER -->
      <div class="current-passenger-info" aria-live="polite">
        <span class="passenger-icon-large">👤</span>
        <div class="current-passenger-text">
          <span class="current-passenger-label">Assigning seat for</span>
          <span class="current-passenger-name" id="current-passenger-name">{{ currentPassenger }}</span>
        </div>
      </div>

      <!-- SEAT SELECTION STATUS -->
      <div class="seat-status-bar" id="status-bar" role="status" aria-live="polite">
        <div class="seat-status-info">
          <span class="seat-status-label">Seats assigned:</span>
          <span class="seat-status-count" id="seat-count">0 / {{ passengers|length }}</span>
        </div>
        <div class="seat-status-list" id="seat-list" aria-label="Selected seat assignments">
          <!-- Filled by javascript -->
        </div>
        <div class="seat-actions">
          <p class="seat-actions-hint" id="hint-text" aria-live="polite">Select a seat for {{ currentPassenger }}</p>
        </div>
        <button type="button" class="btn-reset" id="reset-btn"
          data-has-return="{{ hasReturnFlight }}"
          data-leg="{{ leg }}"
          aria-label="Reset all seats">
          Reset all seats
        </button>
        <button type="button" class="btn-continue" id="continue-btn" style="display:none" aria-disabled="true" aria-label="Continue to next step">
          Continue to next step →
        </button>
      </div>
      
      <!-- HIDDEN: INPUTS SUBMITTED TO FORM -->
      <script type="application/json" id="passenger-data">
      [
        {% for passenger in passengers %}
        {
          "id": {{ passenger.id }},
          "firstName": "{{ passenger.firstName }}",
          "lastName": "{{ passenger.lastName }}"
        }{% if not loop.last %},{% endif %}
        {% endfor %}
      ]
      </script>

      <!-- SEAT MAP -->
      <form id="seat-form" action="/flights/seats" method="post" class="seat-form" data-leg="{{ leg }}">
        <p class="sr-only" id="seat-instructions">
          Select one available seat for each passenger. Selected seats are announced in the status area.
        </p>
        <div class="seatmap-wrapper">
          <div class="seatmap" role="group" aria-labelledby="seatmap-title" aria-describedby="seat-instructions">
            <div class="seatmap-header" id="seatmap-title">Front of Aircraft</div>
            
            {% for row in seatRows %}
              <div class="seat-row">
                <div class="row-num">{{ row.rowNumber }}</div>

                <div class="row-seats">
                  {% for s in row.seats %}
                    {% if s.isAisleGap %}
                      <div class="aisle-gap"></div>
                    {% else %}
                      {% set cls = "seat" %}
                      {% if s.status == "occupied" %}
                        {% set cls = cls ~ " occupied" %}
                      {% else %}
                        {% set cls = cls ~ " available" %}
                      {% endif %}

                      <button
                        class="{{ cls }}"
                        type="button"
                        data-seat-code="{{ s.code }}"
                        data-seat-position="{{ s.position }}"
                        data-seat-status="{{ s.status }}"
                        data-price="{% if s.hasPrice %}£{{ s.price }}{% endif %}"
                        aria-label="Seat {{ s.code }}, {{ s.position }}, {{ s.status }}{% if s.hasPrice %}, £{{ s.price }}{% endif %}"
                        aria-pressed="false"
                        {% if s.status == "occupied" %}disabled{% endif %}
                      >
                        {{ s.letter }}
                      </button>
                    {% endif %}
                  {% endfor %}
                </div>
              </div>
            {% endfor %}
          </div>
        </div>

        <!-- HIDDEN: INPUT SUBMITTED TO FORM -->
        <input type="hidden" id="booking-total-input" name="bookingTotal" value="0.00">
        <input type="hidden" id="selected-seats-input" name="selectedSeats" value="{}">
      </form>

      <script src="/static/javascript/Seat_Selection.js"></script>
    </div>
  </section>
</main>

<!-- FARE SUMMARY -->
<div class="fare-summary" id="fare-summary" data-price="{{ farePrice }}" data-currency="{{ fareCurrency }}">
  <div class="fare-summary-row">
    <span class="fare-summary-label">Base Fare per passenger</span>
    <span class="fare-summary-value">{{ fareCurrency }} {{ farePrice }}</span>
  </div>
  <div class="fare-summary-row">
    <span class="fare-summary-label">Passengers</span>
    <span class="fare-summary-value" id="fare-assigned-count">0 / {{ passengerCount }}</span>
  </div>
  <div class="fare-summary-divider"></div>
  <div class="fare-summary-row fare-summary-total">
    <span class="fare-summary-label">Flight total</span>
    <span class="fare-summary-value" id="fare-running-total">{{ fareCurrency }} 0.00</span>
  </div>
</div>

<!-- SEAT TOOLTIP -->
<div id="seat-tooltip" class="seat-tooltip" aria-hidden="true">
  <div class="seat-tooltip-code" id="tooltip-code"></div>
  <div class="seat-tooltip-row">
    <span class="seat-tooltip-label">Position</span>
    <span class="seat-tooltip-value" id="tooltip-position"></span>
  </div>
  <div class="seat-tooltip-row">
    <span class="seat-tooltip-label">Price</span>
    <span class="seat-tooltip-value" id="tooltip-price"></span>
  </div>
  <div class="seat-tooltip-row">
    <span class="seat-tooltip-label">Status</span>
    <span class="seat-tooltip-value" id="tooltip-status"></span>
  </div>
</div>

<!-- FOOTER -->
{% include "footer.peb" %}

  <script src="/static/javascript/Large_Font.js"></script>
</body>
</html>
