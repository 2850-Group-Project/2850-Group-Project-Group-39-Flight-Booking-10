<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SkyFlow - Seat Selection</title>
  <style>
    body {
      margin: 0;
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji", "Segoe UI Emoji";
      background: radial-gradient(1200px 600px at 10% -10%, rgba(56,189,248,.18), transparent 60%),
                  radial-gradient(900px 500px at 90% 0%, rgba(168,85,247,.16), transparent 55%),
                  #050816;
      color: rgba(255,255,255,.92);
    }

    .wrap { max-width: 1100px; margin: 0 auto; padding: 26px 18px; }
    .topbar { display:flex; justify-content:space-between; align-items:center; padding:14px 16px;
      border:1px solid rgba(255,255,255,.12); border-radius:14px; background:rgba(10,14,25,.55);
      backdrop-filter: blur(10px);
    }
    .brand { display:flex; align-items:center; gap:10px; font-weight:900; }
    .brand-badge { width:36px; height:36px; border-radius:12px; display:grid; place-items:center;
      background: rgba(255,255,255,.10); border: 1px solid rgba(255,255,255,.14);
    }
    .right { display:flex; align-items:center; gap:10px; }
    .navbtn { text-decoration:none; padding:10px 12px; border-radius:12px;
      border:1px solid rgba(255,255,255,.14); background:rgba(255,255,255,.06); color:rgba(255,255,255,.92);
      font-weight:800;
    }
    .navbtn.red { border-color: rgba(239,68,68,.35); background: rgba(239,68,68,.12); }

    .card { margin-top: 18px; padding:18px; border-radius:16px;
      background: rgba(10,14,25,.6); border: 1px solid rgba(255,255,255,.12);
    }
    .sub { color: rgba(255,255,255,.66); font-weight:700; }

    .msg { padding:12px 14px; border-radius:12px; margin:12px 0;
      background: rgba(34,197,94,.14); border: 1px solid rgba(34,197,94,.25);
      color: rgba(255,255,255,.92); font-weight:800;
    }
    .msg.err { background: rgba(239,68,68,.14); border-color: rgba(239,68,68,.28); }

    .divider { text-align:center; margin: 16px 0; color: rgba(255,255,255,.55);
      font-weight:900; letter-spacing:.35em; font-size: 12px;
    }

    .pill { display:inline-flex; gap:8px; align-items:center; padding:10px 12px; border-radius:999px;
      border: 1px solid rgba(255,255,255,.14); background: rgba(255,255,255,.06);
      color: rgba(255,255,255,.88); font-weight:400;
    }
    .info-grid { display:flex; flex-wrap:wrap; gap:10px; }

    .legend { display:flex; flex-wrap:wrap; gap:14px; }
    .lg { display:flex; align-items:center; gap:8px; color: rgba(255,255,255,.78); font-weight:800; }
    .sq { width:14px; height:14px; border-radius:5px; display:inline-block; border:1px solid rgba(255,255,255,.18); }
    .sq.available { background: rgba(34,197,94,.25); }
    .sq.occupied { background: rgba(239,68,68,.22); }
    .sq.current { background: rgba(56,189,248,.25); }

    .seatmap-container {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .seatmap { margin-top: 10px; padding: 16px; border-radius: 16px;
      border: 1px solid rgba(255,255,255,.12); background: rgba(255,255,255,.04);
      overflow-x:auto;
    }
    .seat-row { display:flex; align-items:center; gap:12px; margin: 8px 0; }
    .row-num { width:32px; text-align:right; color: rgba(255,255,255,.60); font-weight:900; }
    .row-seats { display:flex; gap:8px; align-items:center; }
    .aisle-gap { width:22px; height:1px; }

    .seat { width:36px; height:36px; border-radius:12px; border:1px solid rgba(255,255,255,.14);
      background: rgba(255,255,255,.07); color: rgba(255,255,255,.92); font-weight:900;
      cursor:pointer;
    }
    .seat.available:hover { transform: translateY(-1px); }
    .seat.occupied { background: rgba(239,68,68,.16); border-color: rgba(239,68,68,.25); opacity:.55; cursor:not-allowed; }
    .seat.current { outline: 2px solid rgba(56,189,248,.55); outline-offset: 2px; }
  </style>
</head>

<body>
  <div class="wrap">

    <div class="topbar">
      <div class="brand">
        <div class="brand-badge">✈</div>
        <div>SkyFlow</div>
      </div>

      <div class="right">
        <!-- booking flow: go back to passenger details (or flights list) -->
        <a class="navbtn" href="/flights/passengers">← Back to Passenger Details</a>
        <a class="navbtn red" href="/logout">Logout</a>
      </div>
    </div>

    <div class="card" style="margin-top:18px;">
      <h1 style="margin:0;">Seat Selection</h1>
      <p class="sub" style="margin-top:8px;">
        Pick a seat for your flight. Seats marked as occupied cannot be selected.
      </p>

      {% if error %}
        <div class="msg err">{{ error }}</div>
      {% endif %}
      {% if ok %}
        <div class="msg">{{ ok }}</div>
      {% endif %}

      <div class="info-grid" style="margin-top:16px;">
        <div class="pill">Flight: <b>{{ flightNumber }}</b> (ID: {{ flightId }})</div>
        <div class="pill">Route: <b>{{ originIata }}</b> ({{ originName }}) → <b>{{ destIata }}</b> ({{ destName }})</div>
        <div class="pill">Aircraft Type: <b>{{ aircraftType }}</b></div>
        <div class="pill">Selected Seat: <b>{% if currentSeatCode %}{{ currentSeatCode }}{% else %}None{% endif %}</b></div>
      </div>

      <div class="divider" style="margin-top:18px;">CHOOSE A SEAT</div>

      <div class="legend" style="margin:14px 0 10px;">
        <span class="lg"><span class="sq available"></span> Available</span>
        <span class="lg"><span class="sq occupied"></span> Occupied</span>
        <span class="lg"><span class="sq current"></span> Selected</span>
      </div>

      <!-- booking flow: submit to /flights/seats, no bookingId/segmentId hidden fields -->
      <form action="/flights/seats" method="post">
        <div class="seatmap-container">
          <div class="seatmap">
            {% for row in seatRows %}
              <div class="seat-row">
                <div class="row-num">{{ row.rowNumber }}</div>

                <div class="row-seats">
                  {% for s in row.seats %}
                    {% if s.isAisleGap %}
                      <div class="aisle-gap"></div>
                    {% else %}
                      {% set cls = "seat" %}
                      {% if s.status == "occupied" %}
                        {% set cls = cls ~ " occupied" %}
                      {% else %}
                        {% set cls = cls ~ " available" %}
                      {% endif %}
                      {% if currentSeatCode and s.code == currentSeatCode %}
                        {% set cls = cls ~ " current" %}
                      {% endif %}

                      <button
                        class="{{ cls }}"
                        type="submit"
                        name="seatCode"
                        value="{{ s.code }}"
                        {% if s.status == "occupied" %}disabled{% endif %}
                        title="{{ s.code }} • {{ s.position }}"
                      >
                        {{ s.letter }}
                      </button>
                    {% endif %}
                  {% endfor %}
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
        
      </form>
    </div>

  </div>
</body>
</html>