<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Requests</title>
  <link rel="stylesheet" href="/static/css/Profile_Complaints.css">
  <link rel="stylesheet" href="/static/css/Home.css">
</head>
<body>

<nav>
  <a href="/home" class="brand">
    <div class="brand-badge">✈️</div>
    <span class="brand-title">SkyFlow</span>
  </a>
  <div class="nav-right">
      <a href="#" class="btn-ghost" data-large-font-toggle>Large Font</a>
    <a href="/profile/bookings" class="btn-ghost">My Bookings</a>
    <a href="/profile" class="btn-primary">My Account</a>
  </div>
</nav>

<div class="wrap">

  <div class="page-top">
    <div>
      <h1>My Requests</h1>
      <p class="sub">Track the status of requests you have submitted to our support team.</p>
    </div>
    <a href="/complaints" class="btn-new">+ New Request</a>
  </div>

  <!-- COMPLAINTS LIST -->
  {% if complaints is empty %}
    <div class="empty" role="status">
      <div class="empty-icon">📭</div>
      <div class="empty-title">No requests yet</div>
      <p class="empty-sub">If you've experienced an issue, <a href="/complaints">submit a request</a> and we'll look into it.</p>
    </div>
  {% else %}
    <div class="list">
      {% for c in complaints %}
        {% set st = (c.status | default('open')) | lower %}
        <div class="card" style="animation-delay: {{ loop.index * 60 }}ms">

          <div class="card-top">
            <div class="card-meta">
              <div class="complaint-id">#{{ c.id }}</div>
              <div class="type-badge">{{ c.type | default('General') }}</div>
              <div class="pill {{ st }}">
                <span class="dot"></span>
                {{ c.status | default('open') }}
              </div>
            </div>
            <div class="created-at">{{ c.createdAt }}</div>
          </div>

          <div class="message-body">
            {{ c.message }}
          </div>

          {% set responses = responsesByComplaint[c.id] %}
          {% set unread = unreadByComplaint[c.id] %}
            {% if responses is not empty %}
              <div class="response-banner {% if unread > 0 %}response-banner-unread{% endif %}">
                <div style="display:flex; align-items:center; gap:8px;">
                  💬 {{ responses | length }} response{% if responses | length > 1 %}s{% endif %} from support
                  {% if unread > 0 %}
                    <span class="unread-badge">{{ unread }} new</span>
                  {% endif %}
                </div>
                <button class="btn-response" type="button" onclick="toggleResponses({{ c.id }})">View Responses</button>
              </div>

              <div id="responses-{{ c.id }}" class="responses-panel responses-hidden" hidden>
                {% for r in responses %}
                  <div class="response-bubble">
                    <div class="response-meta">Support Staff: {{ r.createdAt }}</div>
                    <div class="response-text">{{ r.message }}</div>
                  </div>
                {% endfor %}
              </div>
            {% endif %}

          {% if c.handledByStaffId %}
            <div class="handled-by">
              <span class="handled-icon">👤</span>
              Currently being processed by our staff
            </div>
          {% endif %}

        </div>
      {% endfor %}
    </div>
  {% endif %}

</div>

<!-- FOOTER -->
<footer>
  <span>© 2026 SkyFlow. All rights reserved</span>
  <div class="footer-links">
    <a href="/privacy">Privacy</a>
    <a href="/terms">Terms</a>
    <a href="/complaints">Help</a>
  </div>
</footer>

  <script src="/static/javascript/Large_Font.js"></script>
  <script>
    function toggleResponses(id) {
      const panel = document.getElementById('responses-' + id);
      const btn = panel.previousElementSibling.querySelector('.btn-response');

      panel.classList.toggle("responses-hidden");
      const isVisible = !panel.classList.contains('responses-hidden');

      btn.textContent = panel.classList.contains("responses-hidden") ? "View Responses" : "Hide Responses";      
      
      // Used Claude AI to generate fetch request for complaints view responses route, lines 117-120
      if (isVisible) {
        fetch("/profile/complaints/view-responses", {
          method: "POST",
          headers: {"Content-Type": "application/x-www-form-urlencoded"},
          body: "complaintId=" + id
        });
      }
    }
  </script>
</body>
</html>
