<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>My Profile</title>
  <link rel="stylesheet" href="/static/css/My_Profile.css">
  <link rel="stylesheet" href="/static/css/Home.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels"></script>
</head>
<body>
  <nav>
    <a href="/home" class="brand">
      <div class="brand-badge">✈️</div>
      <span class="brand-title">SkyFlow</span>
    </a >
    <div class="nav-right">
      <span class="pill">{{ userSession.firstName }} - {{ userSession.userEmail }}</span>
      <a href="#" class="btn-ghost" data-large-font-toggle>Large Font</a>
      <a href="/home" class="btn-ghost">Search</a >
      <a href="/profile/bookings" class="btn-ghost">My Bookings</a >
      <a href="/logout" class="btn-primary">Log Out</a >
    </div>
  </nav>

  <div class="wrap">
    <div class="shell">

      <!-- NAV SIDEBAR OPTIONS -->
      <aside class="side">
        <h3>Navigation</h3>
        <div class="snav">
          <a class="active" href="/profile" aria-current="page"><span class="ico">👤</span> Profile</a >
          <a href="/profile/bookings"><span class="ico">🧾</span> Bookings</a >
          <a href="/profile/complaints"><span class="ico">💬</span> My Inquiries<span class="notif-dot {% if unreadCount > 0 %}unread{% endif %}"></span></a >
          <!-- <a href="/profile/notifications"><span class="ico">🔔</span> Notifications</a > -->
        </div>
      </aside>

      <main class="main">
        <h1>My Profile</h1>
        <p class="sub">View your account information and quickly access bookings and account actions.</p >

        <!-- USER INFO -->
        <div class="grid">
          <section class="card">
            <h2>Profile information</h2>

            <div class="row">
              <div class="k">First name</div>
              <div class="v">{{ userSession.firstName }}</div>
            </div>

            <div class="row">
              <div class="k">Email</div>
              <div class="v">{{ userSession.userEmail }}</div>
            </div>

            <div class="row">
              <div class="k">Account status</div>
              <div class="v">Active</div>
            </div>

            <div class="row">
              <div class="k">Loyalty Points</div>
              <div class="v">{{ pointsBalance }}</div>
            </div>
          </section>

          <aside class="card">
            <h2>Quick actions</h2>
            <p class="sub" style="margin-top:-6px;">Shortcuts to common account tasks.</p >

            <div class="actions">
              <a class="btn-ghost btn-wide" href="/profile/bookings">View My Bookings</a >
              <a class="btn-ghost btn-wide" href="/home">Search Flights</a >
              <a class="btn-primary btn-wide" href="/logout">Log Out</a >
            </div>
          </aside>
        </div>

        <section class="card chart-card" style="margin-top:1.5rem;">
          <!-- <div class="chart-container"> -->
            <canvas id="pointsChart" style="max-height:320px;"></canvas>
          <!-- </div> -->

          <div class="progress-wrap">
            <div class="progress-header">
              <span class="progress-title">Progress to next milestone</span>

              <span class="progress-percent">
                {% if membershipStatus == 'Gold' %}
                  100%
                {% else %}
                  {{ (((totalEarned * 100) / nextMilestone)) | numberformat("0") }}%
                {% endif %}
              </span>
            </div>

            <div class="progress-bar">
              <div
                class="progress-fill"
                style="width:{% if membershipStatus == 'Gold' %}100{% else %}{{ ((totalEarned * 100) / nextMilestone) }}{% endif %}%;">
              </div>
            </div>

            <p class="sub" style="margin-top:.8rem;">
              {{ totalEarned }} / {{ nextMilestone }} total points earned •
              {{ membershipStatus }} →
              {% if membershipStatus == 'Gold' %}
                Gold (max tier)
              {% elseif membershipStatus == 'Silver' %}
                Gold
              {% else %}
                Silver
              {% endif %}
            </p>
          </div>
        </section>

        <section class="points-card card">
          <h2>Loyalty points history</h2>
          {% set hasSpending = false %}
          {% for tx in pointsTransactions %}
              {% set hasSpending = true %}

              <div class="row">
                <div class="v" style="color: {% if tx.type == 'redeem' %}#f5bb0be0{% elseif tx.type == 'earn' %}#22c55e{% endif %};">
                  {{ tx.points }}
                </div>

                <div class="v-description"> 
                  <span style="opacity:0.7;">{{ tx.description }}</span>
                </div>
              </div>

          {% endfor %}

          {% if not hasSpending %}
            <p class="sub">No points spent yet.</p>
          {% endif %}
        </section>
      </main>
    </div>
  </div>

  <!-- FOOTER -->
  <footer>
    <span>© 2026 SkyFlow. All rights reserved</span>
    <div class="footer-links">
      <a href="/privacy">Privacy</a>
      <a href="/terms">Terms</a>
      <a href="/complaints">Help</a>
    </div>
  </footer>

  <script src="/static/javascript/Large_Font.js"></script>
  <script>
    Chart.register(ChartDataLabels);
    Chart.defaults.color = getComputedStyle(document.documentElement).getPropertyValue('--text').trim();

    function renderChart() {
      const existing = Chart.getChart('pointsChart');
      if (existing) existing.destroy();

      const baseFontSize = parseFloat(getComputedStyle(document.body).fontSize);
      const isLargeFont = window.localStorage.getItem('skyflow_large_font') === '1';
      const fontSize = isLargeFont ? baseFontSize * 1.15 : baseFontSize;

      new Chart(document.getElementById('pointsChart'), {
        type: 'bar',
        data: {
          labels: ['Total Earned', 'Total Redeemed', 'Current Balance'],
          datasets: [{
            label: 'Points',
            data: [{{totalEarned}}, {{totalRedeemed}}, {{pointsBalance}}],
            backgroundColor: ['#22c55e', '#ef4444', '#3b82f6'],
            borderRadius: 6,
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: true,
          aspectRatio: 1.5,
          plugins: {
            legend: {display: false},
            title: {
              display: true,
              text: 'Loyalty Points Summary',
              padding: {top: 20, bottom: 30},
              font: {size: fontSize, weight: 'bold'}
            },
            datalabels: {
              anchor: 'end',
              align: 'top',
              font: {size: fontSize, weight: 'bold'}
            }
          },
          scales: {
            y: {
              beginAtZero: true,
              suggestedMax: Math.max({{totalEarned}}, {{totalRedeemed}}, {{pointsBalance}}) * 1.15,
              ticks: {font: {size: fontSize}}
              },
            x: {
              ticks: {font: {size: fontSize}}
            }
          }
        }
      });
    }

    renderChart();

    document.querySelectorAll('[data-large-font-toggle]').forEach(function(toggle) {
      toggle.addEventListener('click', function() {
        setTimeout(renderChart, 50);
      });
    });
  </script>
</body>
</html>
