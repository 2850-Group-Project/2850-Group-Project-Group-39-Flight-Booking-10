<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Login - SkyFlow</title>
  <link rel="stylesheet" href="/static/css/Login.css">
</head>
<body>
  <div class="shell">
    <section class="hero">
      <div class="brand">
        <div class="brand-badge">✈</div>
        <div>SkyFlow</div>
      </div>

      <div class="pill">New Destination: Santorini</div>

      <h1>Elevate Your <span class="grad">Journey</span><br/>Above The Ordinary.</h1>

      <p>
        Experience the future of flight booking. Swift, secure, and tailored to your preferences.
        Your next adventure starts with a single click.
      </p >

      <div class="hero-cards">
        <div class="hcard">
          <div class="hcard-title"><span class="icon">🌐</span> Global Network</div>
          <small>Access 1,200+ destinations across 180 countries with our premium partner airlines.</small>
        </div>
        <div class="hcard">
          <div class="hcard-title"><span class="icon">✨</span> Smart Booking</div>
          <small>Personalized suggestions and best-value fare options to help you book faster.</small>
        </div>
      </div>

      <div class="quote">“The best booking experience I’ve had in years.” — @travel_enthusiast</div>
    </section>

    <main class="panel">
      <div class="card">
        <h2>Welcome Back</h2>
        <p class="sub">Enter your credentials to access your flights and rewards.</p >

        {% if error %}
          <div class="error">{{ error }}</div>
        {% endif %}

        <div class="row">
          <button class="btn" type="button">Google</button>
          <button class="btn" type="button">Apple</button>
        </div>

        <div class="divider">OR CONTINUE WITH EMAIL</div>

        <form action="/login" method="post">
          <label for="email">Email Address</label>
          <div class="field">
            <input class="input" id="email" type="email" name="email" placeholder="you@example.com" required />
          </div>

          <label for="password">Password</label>
          <div class="field">
            <input class="input" id="password" type="password" name="password" placeholder="••••••••" required />
          </div>

          <div class="meta">
            <label style="margin:0; display:flex; align-items:center; gap:8px; font-weight:600;">
              <input type="checkbox" name="remember" />
              Remember me
            </label>
            <a href=" " onclick="return false;">Forgot password?</a >
          </div>

          <button class="primary" type="submit">Sign In →</button>
        </form>

        <div class="cta">
          <span>Don’t have an account?</span>
          <a href="/register">Create Account</a >
        </div>
        <div class="cta" style="margin-top:10px;">
          <span>Staff?</span>
          <a href="/staff/login">Login as staff</a >
        </div>

        <div class="footer">
          <a href="#" onclick="return false;">Privacy Policy</a >
          <span>•</span>
          <a href="#" onclick="return false;">Terms of Service</a >
          <span>•</span>
          <a href="#" onclick="return false;">Help Center</a >
        </div>
      </div>
    </main>
  </div>
</body>
</html>